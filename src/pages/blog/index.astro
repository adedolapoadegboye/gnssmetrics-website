---
import Layout from '../../layouts/Layout.astro';

const posts = [
  {
    href: '/blog/leo-pnt',
    title: 'LEO PNT: The Slow and Steady Rise of a New Navigation Layer',
    date: 'April 2026',
    readTime: '8 min',
    excerpt: 'For forty years, satellite navigation has meant medium Earth orbit. That assumption is quietly being challenged. Fourteen dedicated LEO PNT programmes, the first production satellite in orbit, and the physics of why closer is better.',
    tags: ['LEO PNT', 'GNSS Resilience', 'Xona Pulsar'],
  },
];
---
<Layout
  title="GNSS Blog — Technical Articles on Satellite Navigation"
  description="Technical GNSS articles by practitioners: LEO PNT systems, RTK accuracy analysis, positioning algorithm deep-dives, ionospheric effects, and satellite navigation technology evaluations."
>
  <section class="section">
    <div class="container">

      <span class="badge">Blog</span>
      <h1>Blog</h1>
      <p class="sub">
        Perspective on GNSS technology, emerging systems and the industry.
        Written by a practitioner for practitioners.
      </p>

      <div class="posts-list">
        {posts.map(p => (
          <a href={p.href} class="post-card">
            <div class="post-body">
              <div class="post-title">{p.title}</div>
              <div class="post-excerpt">{p.excerpt}</div>
              <div class="post-tags">
                {p.tags.map(t => <span class="post-tag">{t}</span>)}
              </div>
            </div>
            <div class="post-meta">
              <span class="post-date">{p.date}</span>
              <span class="post-read">{p.readTime} read</span>
              <span class="post-arrow">→</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  h1 { font-size: clamp(26px, 4vw, 36px); font-weight: 700; margin: 10px 0 14px; }
  .sub { color: var(--text2); max-width: 500px; font-size: 15px; line-height: 1.7; margin-bottom: 36px; }

  .posts-list { display: flex; flex-direction: column; gap: 2px; max-width: 820px; }
  .post-card { display: grid; grid-template-columns: 1fr 120px; gap: 24px; align-items: start; padding: 28px; background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; transition: border-color 0.2s, transform 0.15s; }
  .post-card:hover { border-color: rgba(0,212,170,0.3); transform: translateY(-2px); }
  .post-title { font-size: 18px; font-weight: 700; color: var(--text); margin-bottom: 10px; line-height: 1.3; }
  .post-excerpt { font-size: 14px; color: var(--text2); line-height: 1.7; margin-bottom: 12px; }
  .post-tags { display: flex; flex-wrap: wrap; gap: 6px; }
  .post-tag { font-size: 11px; font-family: var(--mono); padding: 3px 8px; background: var(--bg3); border: 1px solid var(--border); border-radius: 20px; color: var(--text3); }
  .post-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; padding-top: 4px; }
  .post-date { font-size: 12px; font-family: var(--mono); color: var(--text3); }
  .post-read { font-size: 11px; font-family: var(--mono); color: var(--text3); }
  .post-arrow { font-size: 18px; color: var(--accent); margin-top: auto; }

  @media (max-width: 600px) {
    .post-card { grid-template-columns: 1fr; }
    .post-meta { flex-direction: row; align-items: center; }
    .post-arrow { margin-top: 0; margin-left: auto; }
  }
</style>