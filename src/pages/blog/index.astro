---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="Blog">
  <section class="section">
    <div class="container">
      <span class="badge">Blog</span>
      <h1>Technical Articles</h1>
      <p class="sub">Field notes, deep dives, evaluations and tutorials — written by practitioners working with GNSS hardware.</p>
      <div class="coming-soon">
        <div class="cs-icon">✍️</div>
        <h3>First articles coming soon</h3>
        <p>Subscribe to the newsletter to be notified when new articles are published.</p>
      </div>
    </div>
  </section>
</Layout>
<style>
  h1 { font-size: 36px; font-weight: 700; margin: 12px 0; }
  .sub { color: var(--text2); margin-bottom: 40px; max-width: 560px; }
  .coming-soon { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 60px 40px; text-align: center; max-width: 480px; }
  .cs-icon { font-size: 40px; margin-bottom: 16px; }
  .coming-soon h3 { font-size: 20px; font-weight: 600; margin-bottom: 10px; }
  .coming-soon p { font-size: 14px; color: var(--text2); }
</style>
