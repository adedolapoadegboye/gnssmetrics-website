---
import Layout from '../../layouts/Layout.astro';

const tools = [
  {
    href: '/tools/gnss-analyzer',
    title: 'GNSS Analyzer',
    desc: 'Full NMEA, RINEX, RTK and Quectel PQTM analysis suite. Multi-file, multi-constellation.',
    tags: ['NMEA', 'RINEX', 'RTK', 'PQTM'],
    status: 'live',
    icon: '⚙️',
  },
  {
    href: '/tools/time-converter',
    title: 'GNSS Time Converter',
    desc: 'Convert between GPS Week/TOW, UTC, Unix, Julian Date, Day of Year and all constellation epochs. Handles leap seconds and GPS week rollover.',
    tags: ['GPS', 'Galileo', 'BeiDou', 'GLONASS'],
    status: 'live',
    icon: '⏱️',
  },
  {
    href: '/tools/nmea-converter',
    title: 'NMEA to KML / GeoJSON',
    desc: 'Upload an NMEA log file and download a track as KML, KMZ or GeoJSON — ready to open in Google Earth or QGIS.',
    tags: ['NMEA', 'KML', 'GeoJSON'],
    status: 'soon',
    icon: '🗺️',
  },
  {
    href: '/tools/dop-calculator',
    title: 'DOP Calculator',
    desc: 'Enter satellite azimuths and elevations, compute HDOP, VDOP and PDOP from the design matrix.',
    tags: ['HDOP', 'VDOP', 'PDOP'],
    status: 'soon',
    icon: '📐',
  },
  {
    href: '/tools/rinex-inspector',
    title: 'RINEX Header Inspector',
    desc: 'Upload a RINEX 2 or 3 observation file and inspect header metadata — receiver, antenna, observables, epochs — without needing any software.',
    tags: ['RINEX', 'Observation'],
    status: 'soon',
    icon: '🔍',
  },
  {
    href: '/tools/coordinate-converter',
    title: 'Coordinate Converter',
    desc: 'Convert between ECEF Cartesian, Geodetic (lat/lon/height) and ENU. Supports WGS84 and GRS80.',
    tags: ['ECEF', 'Geodetic', 'ENU'],
    status: 'soon',
    icon: '🌐',
  },
  {
    href: '/tools/nmea-decoder',
    title: 'NMEA Sentence Decoder',
    desc: 'Paste any NMEA sentence — GGA, RMC, GSA, GSV — and get a field-by-field breakdown with validation.',
    tags: ['NMEA', 'GGA', 'RMC'],
    status: 'soon',
    icon: '📋',
  },
  {
    href: '/tools/klobuchar',
    title: 'Klobuchar Calculator',
    desc: 'Enter the 8 Klobuchar coefficients from a GPS navigation message and compute the ionospheric delay on L1.',
    tags: ['Ionosphere', 'L1', 'GPS'],
    status: 'soon',
    icon: '🌤️',
  },
  {
    href: '/tools/ubx-parser',
    title: 'UBX Frame Parser',
    desc: 'Paste u-blox UBX hex bytes and decode the message class, ID, payload fields and checksum.',
    tags: ['UBX', 'u-blox', 'Binary'],
    status: 'soon',
    icon: '🔩',
  },
];

const liveTools = tools.filter(t => t.status === 'live');
const soonTools = tools.filter(t => t.status === 'soon');
---
<Layout title="Tools — GNSSMetrics">
  <section class="section">
    <div class="container">

      <span class="badge">Tools</span>
      <h1>GNSS Analysis Tools</h1>
      <p class="sub">
        Browser-based tools for GNSS engineers. No installation, no account required.
        All computation runs locally — no data leaves your device.
      </p>

      <!-- Live tools -->
      <div class="section-label">Available now</div>
      <div class="tools-grid">
        {liveTools.map(t => (
          <a href={t.href} class="tool-card tool-live">
            <div class="tool-icon">{t.icon}</div>
            <div class="tool-body">
              <div class="tool-title">{t.title}</div>
              <div class="tool-desc">{t.desc}</div>
              <div class="tool-tags">
                {t.tags.map(tag => <span class="tool-tag">{tag}</span>)}
              </div>
            </div>
            <div class="tool-arrow">→</div>
          </a>
        ))}
      </div>

      <!-- Coming soon tools -->
      <div class="section-label section-label-soon">Coming soon</div>
      <div class="tools-grid">
        {soonTools.map(t => (
          <div class="tool-card tool-soon">
            <div class="tool-icon">{t.icon}</div>
            <div class="tool-body">
              <div class="tool-title">{t.title}</div>
              <div class="tool-desc">{t.desc}</div>
              <div class="tool-tags">
                {t.tags.map(tag => <span class="tool-tag">{tag}</span>)}
              </div>
            </div>
            <div class="tool-coming">Coming soon</div>
          </div>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  h1 { font-size: clamp(26px, 4vw, 36px); font-weight: 700; margin: 10px 0 14px; }
  .sub { color: var(--text2); max-width: 560px; font-size: 15px; line-height: 1.7; margin-bottom: 32px; }

  .section-label { font-size: 10px; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--accent); font-family: var(--mono); margin-bottom: 12px; }
  .section-label-soon { margin-top: 32px; color: var(--text3); }

  .tools-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 10px; max-width: 900px; margin-bottom: 4px; }

  .tool-card { display: grid; grid-template-columns: 44px 1fr auto; gap: 16px; align-items: start; padding: 22px; background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; }
  .tool-live { transition: border-color 0.2s, transform 0.15s; cursor: pointer; }
  .tool-live:hover { border-color: rgba(0,212,170,0.4); transform: translateY(-2px); }
  .tool-soon { opacity: 0.45; cursor: default; }

  .tool-icon { font-size: 22px; padding-top: 2px; }
  .tool-title { font-size: 15px; font-weight: 700; color: var(--text); margin-bottom: 6px; }
  .tool-desc { font-size: 13px; color: var(--text2); line-height: 1.6; margin-bottom: 10px; }
  .tool-tags { display: flex; flex-wrap: wrap; gap: 5px; }
  .tool-tag { font-size: 10px; font-family: var(--mono); padding: 2px 7px; background: var(--bg3); border: 1px solid var(--border); border-radius: 20px; color: var(--text3); }

  .tool-arrow { font-size: 18px; color: var(--accent); padding-top: 2px; }
  .tool-coming { font-size: 10px; font-family: var(--mono); color: var(--text3); white-space: nowrap; padding-top: 4px; }

  @media (max-width: 700px) {
    .tools-grid { grid-template-columns: 1fr; }
    .tool-card { grid-template-columns: 40px 1fr auto; gap: 12px; padding: 16px; }
  }
</style>