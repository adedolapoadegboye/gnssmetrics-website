---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="DOP Calculator">
  <section class="section">
    <div class="container">

      <a href="/tools" class="back">← All tools</a>

      <div class="tool-header">
        <span class="badge">Tool</span>
        <h1>DOP Calculator</h1>
        <p class="sub">
          Enter satellite azimuths and elevations to compute HDOP, VDOP, PDOP, TDOP and GDOP
          from the design matrix. Add satellites manually or paste a NMEA GSA/GSV block.
        </p>
      </div>

      <!-- INPUT AREA -->
      <div class="input-grid">

        <!-- LEFT: Manual satellite entry -->
        <div class="input-panel">
          <div class="panel-title">Satellites</div>

          <div class="sat-table">
            <div class="sat-row sat-header">
              <span>#</span>
              <span>Azimuth (°)</span>
              <span>Elevation (°)</span>
              <span>System</span>
              <span></span>
            </div>
            <div id="satRows"></div>
          </div>

          <div class="sat-actions">
            <button class="btn-add" id="addSatBtn">+ Add satellite</button>
            <button class="btn-secondary" id="clearSatsBtn">Clear all</button>
          </div>

          <div class="preset-section">
            <div class="preset-label">Load example geometry</div>
            <div class="preset-btns">
              <button class="preset-btn" data-preset="good">Good (8 sats)</button>
              <button class="preset-btn" data-preset="poor">Poor (4 sats)</button>
              <button class="preset-btn" data-preset="rtk">RTK spread (12 sats)</button>
            </div>
          </div>

          <div class="nmea-paste-section">
            <div class="preset-label">Or paste NMEA GSV sentences</div>
            <textarea id="nmeaPaste" rows="4" placeholder="$GPGSV,3,1,11,03,34,247,47,06,79,338,45,07,16,106,41,11,18,042,32*7B&#10;$GPGSV,3,2,11,14,33,161,40,17,54,253,47,19,27,313,42,22,06,078,31*7A"></textarea>
            <button class="btn-parse-nmea" id="parseNmeaBtn">Parse GSV</button>
            <div class="nmea-error" id="nmeaError" style="display:none"></div>
          </div>
        </div>

        <!-- RIGHT: Results -->
        <div class="results-panel">
          <div class="panel-title">DOP Values</div>

          <div class="dop-grid">
            <div class="dop-card dop-hdop">
              <div class="dop-name">HDOP</div>
              <div class="dop-full">Horizontal</div>
              <div class="dop-value" id="hdop">—</div>
              <div class="dop-rating" id="hdopRating"></div>
            </div>
            <div class="dop-card dop-vdop">
              <div class="dop-name">VDOP</div>
              <div class="dop-full">Vertical</div>
              <div class="dop-value" id="vdop">—</div>
              <div class="dop-rating" id="vdopRating"></div>
            </div>
            <div class="dop-card dop-pdop">
              <div class="dop-name">PDOP</div>
              <div class="dop-full">Position (3D)</div>
              <div class="dop-value" id="pdop">—</div>
              <div class="dop-rating" id="pdopRating"></div>
            </div>
            <div class="dop-card">
              <div class="dop-name">TDOP</div>
              <div class="dop-full">Time</div>
              <div class="dop-value" id="tdop">—</div>
              <div class="dop-rating" id="tdopRating"></div>
            </div>
            <div class="dop-card">
              <div class="dop-name">GDOP</div>
              <div class="dop-full">Geometric (4D)</div>
              <div class="dop-value" id="gdop">—</div>
              <div class="dop-rating" id="gdopRating"></div>
            </div>
          </div>

          <div class="dop-formula">
            <div class="formula-title">Q = (AᵀA)⁻¹</div>
            <div class="formula-body" id="qMatrix">Add at least 4 satellites to compute</div>
          </div>

          <!-- Sky plot -->
          <div class="skyplot-wrap">
            <div class="panel-title">Sky plot</div>
            <canvas id="skyCanvas" width="260" height="260"></canvas>
            <div class="sky-legend">
              <span class="sky-l gps">● GPS</span>
              <span class="sky-l gal">● Galileo</span>
              <span class="sky-l bds">● BeiDou</span>
              <span class="sky-l glo">● GLONASS</span>
            </div>
          </div>
        </div>
      </div>

      <!-- DOP RATING REFERENCE -->
      <div class="ref-section">
        <div class="ref-title">DOP Rating Reference</div>
        <div class="dop-ref-table">
          <div class="drt-row drt-header">
            <span>DOP Value</span>
            <span>Rating</span>
            <span>Positioning confidence</span>
            <span>Typical scenario</span>
          </div>
          <div class="drt-row">
            <span class="drt-val ideal">1</span>
            <span class="ideal">Ideal</span>
            <span>Highest possible confidence. Theoretical maximum geometry.</span>
            <span>Open sky, many satellites, well-spread geometry</span>
          </div>
          <div class="drt-row">
            <span class="drt-val excellent">1–2</span>
            <span class="excellent">Excellent</span>
            <span>Accuracy at or near the limit of the receiver's ranging noise.</span>
            <span>Survey-grade operations, open sky</span>
          </div>
          <div class="drt-row">
            <span class="drt-val good">2–5</span>
            <span class="good">Good</span>
            <span>Adequate for most positioning applications.</span>
            <span>Standard navigation, mapping, most RTK work</span>
          </div>
          <div class="drt-row">
            <span class="drt-val moderate">5–10</span>
            <span class="moderate">Moderate</span>
            <span>Accuracy degraded. Acceptable for coarse navigation only.</span>
            <span>Partial sky obstruction, urban areas</span>
          </div>
          <div class="drt-row">
            <span class="drt-val poor">10–20</span>
            <span class="poor">Poor</span>
            <span>Low confidence position. Use with caution.</span>
            <span>Heavy urban canyon, foliage</span>
          </div>
          <div class="drt-row">
            <span class="drt-val bad">&gt; 20</span>
            <span class="bad">Unusable</span>
            <span>Position unreliable. Do not use for navigation or survey.</span>
            <span>Severe obstruction, near-vertical satellite cluster</span>
          </div>
        </div>
      </div>

      <!-- MATHS EXPLAINER -->
      <div class="ref-section">
        <div class="ref-title">How DOP is computed</div>
        <div class="explainer">
          <p>
            For each satellite i at elevation angle el_i and azimuth az_i, the unit vector
            from receiver to satellite in East-North-Up (ENU) is:
          </p>
          <div class="math-block">
            <div>e_i = cos(el_i) · sin(az_i)</div>
            <div>n_i = cos(el_i) · cos(az_i)</div>
            <div>u_i = sin(el_i)</div>
          </div>
          <p>
            The design matrix A has one row per satellite, with columns [e, n, u, 1]
            (the 1 is the receiver clock term):
          </p>
          <div class="math-block">
            <div>A = ⎡ e₁  n₁  u₁  1 ⎤</div>
            <div>    ⎢ e₂  n₂  u₂  1 ⎥</div>
            <div>    ⎣ ...          ...⎦</div>
          </div>
          <p>
            The covariance matrix Q = (AᵀA)⁻¹. The DOP values are extracted from the
            diagonal elements of Q:
          </p>
          <div class="math-block">
            <div>HDOP = √(Q[0,0] + Q[1,1])   (East + North)</div>
            <div>VDOP = √(Q[2,2])              (Up)</div>
            <div>PDOP = √(Q[0,0] + Q[1,1] + Q[2,2])</div>
            <div>TDOP = √(Q[3,3])              (Clock)</div>
            <div>GDOP = √(trace(Q))</div>
          </div>
        </div>
      </div>

    </div>
  </section>
</Layout>

<script>
// ─── State ────────────────────────────────────────────────────────────────────
let satellites = [];
let rowCounter = 0;

const SYSTEMS = ['GPS', 'Galileo', 'BeiDou', 'GLONASS', 'QZSS'];
const SYS_COLORS = { GPS: '#fbbf24', Galileo: '#0099ff', BeiDou: '#f97316', GLONASS: '#a3e635', QZSS: '#c084fc' };

// ─── Presets ──────────────────────────────────────────────────────────────────
const PRESETS = {
  good: [
    { az: 45,  el: 60, sys: 'GPS' },
    { az: 135, el: 45, sys: 'GPS' },
    { az: 225, el: 55, sys: 'GPS' },
    { az: 315, el: 50, sys: 'GPS' },
    { az: 90,  el: 30, sys: 'Galileo' },
    { az: 180, el: 35, sys: 'Galileo' },
    { az: 270, el: 40, sys: 'BeiDou' },
    { az: 350, el: 25, sys: 'BeiDou' },
  ],
  poor: [
    { az: 10,  el: 20, sys: 'GPS' },
    { az: 30,  el: 25, sys: 'GPS' },
    { az: 50,  el: 15, sys: 'GPS' },
    { az: 70,  el: 20, sys: 'GPS' },
  ],
  rtk: [
    { az: 0,   el: 70, sys: 'GPS' },
    { az: 45,  el: 55, sys: 'GPS' },
    { az: 90,  el: 40, sys: 'GPS' },
    { az: 135, el: 60, sys: 'Galileo' },
    { az: 180, el: 45, sys: 'Galileo' },
    { az: 225, el: 35, sys: 'Galileo' },
    { az: 270, el: 50, sys: 'BeiDou' },
    { az: 315, el: 65, sys: 'BeiDou' },
    { az: 22,  el: 30, sys: 'GLONASS' },
    { az: 112, el: 25, sys: 'GLONASS' },
    { az: 202, el: 20, sys: 'GLONASS' },
    { az: 292, el: 28, sys: 'GLONASS' },
  ],
};

// ─── Matrix helpers ───────────────────────────────────────────────────────────
function matMul(A, B) {
  const rows = A.length, cols = B[0].length, inner = B.length;
  return Array.from({ length: rows }, (_, i) =>
    Array.from({ length: cols }, (_, j) =>
      A[i].reduce((s, _, k) => s + A[i][k] * B[k][j], 0)
    )
  );
}

function matTranspose(A) {
  return A[0].map((_, j) => A.map(row => row[j]));
}

// 4x4 matrix inverse via Gaussian elimination
function mat4inv(m) {
  const n = 4;
  const a = m.map(row => [...row]);
  const inv = Array.from({ length: n }, (_, i) => Array.from({ length: n }, (_, j) => i === j ? 1 : 0));

  for (let col = 0; col < n; col++) {
    // Find pivot
    let pivotRow = -1;
    let pivotVal = 0;
    for (let row = col; row < n; row++) {
      if (Math.abs(a[row][col]) > Math.abs(pivotVal)) { pivotVal = a[row][col]; pivotRow = row; }
    }
    if (pivotRow < 0 || Math.abs(pivotVal) < 1e-12) return null; // singular

    // Swap
    [a[col], a[pivotRow]] = [a[pivotRow], a[col]];
    [inv[col], inv[pivotRow]] = [inv[pivotRow], inv[col]];

    // Scale pivot row
    const scale = a[col][col];
    for (let j = 0; j < n; j++) { a[col][j] /= scale; inv[col][j] /= scale; }

    // Eliminate column
    for (let row = 0; row < n; row++) {
      if (row === col) continue;
      const factor = a[row][col];
      for (let j = 0; j < n; j++) { a[row][j] -= factor * a[col][j]; inv[row][j] -= factor * inv[col][j]; }
    }
  }
  return inv;
}

// ─── DOP calculation ──────────────────────────────────────────────────────────
function computeDOP(sats) {
  if (sats.length < 4) return null;

  const deg = Math.PI / 180;
  const A = sats.map(s => {
    const el = s.el * deg, az = s.az * deg;
    return [
      Math.cos(el) * Math.sin(az),  // East
      Math.cos(el) * Math.cos(az),  // North
      Math.sin(el),                  // Up
      1,                             // Clock
    ];
  });

  const AT = matTranspose(A);
  const ATA = matMul(AT, A);
  const Q = mat4inv(ATA);
  if (!Q) return null;

  return {
    Q,
    hdop: Math.sqrt(Math.max(0, Q[0][0] + Q[1][1])),
    vdop: Math.sqrt(Math.max(0, Q[2][2])),
    pdop: Math.sqrt(Math.max(0, Q[0][0] + Q[1][1] + Q[2][2])),
    tdop: Math.sqrt(Math.max(0, Q[3][3])),
    gdop: Math.sqrt(Math.max(0, Q[0][0] + Q[1][1] + Q[2][2] + Q[3][3])),
  };
}

function dopRating(val) {
  if (val <= 1)  return { text: 'Ideal',     cls: 'ideal' };
  if (val <= 2)  return { text: 'Excellent', cls: 'excellent' };
  if (val <= 5)  return { text: 'Good',      cls: 'good' };
  if (val <= 10) return { text: 'Moderate',  cls: 'moderate' };
  if (val <= 20) return { text: 'Poor',      cls: 'poor' };
  return             { text: 'Unusable',  cls: 'bad' };
}

function setDOP(id, ratingId, val) {
  const el = document.getElementById(id);
  const rel = document.getElementById(ratingId);
  if (!el) return;
  if (val === null || isNaN(val)) {
    el.textContent = '—'; el.className = 'dop-value';
    if (rel) rel.textContent = '';
    return;
  }
  el.textContent = val.toFixed(2);
  const r = dopRating(val);
  el.className = 'dop-value dv-' + r.cls;
  if (rel) { rel.textContent = r.text; rel.className = 'dop-rating dr-' + r.cls; }
}

// ─── Sky plot ─────────────────────────────────────────────────────────────────
function drawSkyPlot(sats) {
  const canvas = document.getElementById('skyCanvas');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  const W = canvas.width, H = canvas.height;
  const cx = W / 2, cy = H / 2;
  const R = (W / 2) - 20;
  ctx.clearRect(0, 0, W, H);

  // Background
  ctx.fillStyle = 'var(--bg3)' ;
  ctx.beginPath(); ctx.arc(cx, cy, R, 0, Math.PI * 2); ctx.fill();

  // Rings at 0°, 30°, 60°, 90° elevation
  const rings = [0, 30, 60, 90];
  for (const el of rings) {
    const r = R * (1 - el / 90);
    ctx.beginPath();
    ctx.strokeStyle = 'rgba(255,255,255,0.08)';
    ctx.lineWidth = 0.5;
    ctx.arc(cx, cy, r, 0, Math.PI * 2);
    ctx.stroke();
    if (el > 0) {
      ctx.fillStyle = 'rgba(255,255,255,0.2)';
      ctx.font = '9px var(--mono, monospace)';
      ctx.fillText(el + '°', cx + r + 2, cy + 3);
    }
  }

  // Cardinal lines
  ctx.strokeStyle = 'rgba(255,255,255,0.08)';
  ctx.lineWidth = 0.5;
  for (const angle of [0, 90, 180, 270]) {
    const rad = (angle - 90) * Math.PI / 180;
    ctx.beginPath();
    ctx.moveTo(cx, cy);
    ctx.lineTo(cx + R * Math.cos(rad), cy + R * Math.sin(rad));
    ctx.stroke();
  }

  // Cardinal labels
  ctx.fillStyle = 'rgba(255,255,255,0.3)';
  ctx.font = '10px var(--mono, monospace)';
  ctx.textAlign = 'center';
  ctx.fillText('N', cx, cy - R - 6);
  ctx.fillText('S', cx, cy + R + 14);
  ctx.fillText('E', cx + R + 8, cy + 4);
  ctx.fillText('W', cx - R - 8, cy + 4);

  // Elevation mask line at 10°
  const maskR = R * (1 - 10 / 90);
  ctx.beginPath();
  ctx.strokeStyle = 'rgba(255,71,87,0.3)';
  ctx.lineWidth = 1;
  ctx.setLineDash([4, 3]);
  ctx.arc(cx, cy, maskR, 0, Math.PI * 2);
  ctx.stroke();
  ctx.setLineDash([]);

  // Satellites
  for (const sat of sats) {
    const r = R * (1 - sat.el / 90);
    const rad = (sat.az - 90) * Math.PI / 180;
    const x = cx + r * Math.cos(rad);
    const y = cy + r * Math.sin(rad);
    const color = SYS_COLORS[sat.sys] || '#fbbf24';

    ctx.beginPath();
    ctx.fillStyle = color + 'cc';
    ctx.strokeStyle = color;
    ctx.lineWidth = 1.5;
    ctx.arc(x, y, 7, 0, Math.PI * 2);
    ctx.fill();
    ctx.stroke();

    // Satellite number label
    ctx.fillStyle = '#000';
    ctx.font = 'bold 7px var(--mono, monospace)';
    ctx.textAlign = 'center';
    ctx.fillText(sat.id || '·', x, y + 3);
  }

  ctx.textAlign = 'left';
}

// ─── UI: satellite rows ───────────────────────────────────────────────────────
function addSatRow(az = '', el = '', sys = 'GPS') {
  rowCounter++;
  const id = rowCounter;
  const container = document.getElementById('satRows');
  const row = document.createElement('div');
  row.className = 'sat-row sat-data';
  row.dataset.id = id;
  row.innerHTML = `
    <span class="sat-num">${satellites.length + 1}</span>
    <input type="number" class="sat-input az-input" placeholder="0–359" min="0" max="359" value="${az}" data-field="az" />
    <input type="number" class="sat-input el-input" placeholder="5–90" min="0" max="90" value="${el}" data-field="el" />
    <select class="sat-select sys-select" data-field="sys">
      ${SYSTEMS.map(s => `<option value="${s}"${s === sys ? ' selected' : ''}>${s}</option>`).join('')}
    </select>
    <button class="sat-del" data-id="${id}">✕</button>
  `;
  container.appendChild(row);

  const sat = { id: rowCounter, az: parseFloat(az) || 0, el: parseFloat(el) || 0, sys };
  satellites.push(sat);

  // Wire inputs
  row.querySelectorAll('input, select').forEach(inp => {
    inp.addEventListener('input', () => {
      const field = inp.dataset.field;
      const satIdx = satellites.findIndex(s => s.id === id);
      if (satIdx < 0) return;
      if (field === 'az' || field === 'el') satellites[satIdx][field] = parseFloat(inp.value) || 0;
      else satellites[satIdx][field] = inp.value;
      recalculate();
    });
  });

  row.querySelector('.sat-del').addEventListener('click', () => {
    satellites = satellites.filter(s => s.id !== id);
    row.remove();
    renumberRows();
    recalculate();
  });

  recalculate();
}

function renumberRows() {
  document.querySelectorAll('.sat-data').forEach((row, i) => {
    const numEl = row.querySelector('.sat-num');
    if (numEl) numEl.textContent = i + 1;
  });
}

function clearAllSats() {
  satellites = [];
  document.getElementById('satRows').innerHTML = '';
  recalculate();
}

// ─── Recalculate ──────────────────────────────────────────────────────────────
function recalculate() {
  // Filter valid sats (need az and el)
  const valid = satellites.filter(s => !isNaN(s.az) && !isNaN(s.el) && s.el >= 0 && s.el <= 90);

  drawSkyPlot(valid.map((s, i) => ({ ...s, id: i + 1 })));

  if (valid.length < 4) {
    ['hdop','vdop','pdop','tdop','gdop'].forEach(id => setDOP(id, id + 'Rating', null));
    document.getElementById('qMatrix').textContent = `Need at least 4 satellites (have ${valid.length})`;
    return;
  }

  const result = computeDOP(valid);
  if (!result) {
    ['hdop','vdop','pdop','tdop','gdop'].forEach(id => setDOP(id, id + 'Rating', null));
    document.getElementById('qMatrix').textContent = 'Singular geometry — satellites may be collinear';
    return;
  }

  setDOP('hdop', 'hdopRating', result.hdop);
  setDOP('vdop', 'vdopRating', result.vdop);
  setDOP('pdop', 'pdopRating', result.pdop);
  setDOP('tdop', 'tdopRating', result.tdop);
  setDOP('gdop', 'gdopRating', result.gdop);

  // Show Q matrix diagonal
  const Q = result.Q;
  document.getElementById('qMatrix').innerHTML =
    `<span class="q-label">Q diagonal (σ² factors):</span><br/>` +
    `Q[E,E] = ${Q[0][0].toFixed(4)} &nbsp; Q[N,N] = ${Q[1][1].toFixed(4)} &nbsp; Q[U,U] = ${Q[2][2].toFixed(4)} &nbsp; Q[t,t] = ${Q[3][3].toFixed(4)}`;
}

// ─── NMEA GSV parser ──────────────────────────────────────────────────────────
function parseGSV(text) {
  const lines = text.split(/\r?\n/).map(l => l.trim()).filter(l => l.startsWith('$'));
  const sats = [];

  for (const line of lines) {
    const star = line.indexOf('*');
    const body = star >= 0 ? line.slice(1, star) : line.slice(1);
    const fields = body.split(',');
    const type = fields[0].slice(-3);
    if (type !== 'GSV') continue;

    // Determine system from talker
    const talker = fields[0].slice(0, -3).replace('$', '');
    const sys = talker === 'GP' ? 'GPS' : talker === 'GL' ? 'GLONASS' : talker === 'GA' ? 'Galileo' : talker === 'GB' || talker === 'BD' ? 'BeiDou' : 'GPS';

    // Each GSV sentence has up to 4 satellite blocks starting at field 4
    for (let i = 4; i + 3 <= fields.length; i += 4) {
      const el = parseFloat(fields[i + 1]);
      const az = parseFloat(fields[i + 2]);
      if (!isNaN(el) && !isNaN(az) && el >= 0 && el <= 90 && az >= 0 && az <= 360) {
        sats.push({ az, el, sys });
      }
    }
  }
  return sats;
}

// ─── Wire up DOM ──────────────────────────────────────────────────────────────
document.addEventListener('DOMContentLoaded', () => {
  document.getElementById('addSatBtn').addEventListener('click', () => addSatRow());
  document.getElementById('clearSatsBtn').addEventListener('click', clearAllSats);

  // Presets
  document.querySelectorAll('.preset-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      clearAllSats();
      const preset = PRESETS[btn.dataset.preset] || [];
      preset.forEach(s => addSatRow(s.az, s.el, s.sys));
    });
  });

  // Parse NMEA GSV
  document.getElementById('parseNmeaBtn').addEventListener('click', () => {
    const text = document.getElementById('nmeaPaste').value;
    const errEl = document.getElementById('nmeaError');
    const sats = parseGSV(text);
    if (sats.length === 0) {
      errEl.textContent = 'No valid GSV sentences found. Paste $GPGSV / $GAGSV / $GLGSV sentences.';
      errEl.style.display = 'block';
      return;
    }
    errEl.style.display = 'none';
    clearAllSats();
    sats.forEach(s => addSatRow(s.az, s.el, s.sys));
  });

  // Load good preset by default
  PRESETS.good.forEach(s => addSatRow(s.az, s.el, s.sys));
});
</script>

<style>
  .back { font-size: 13px; color: var(--text2); display: inline-block; margin-bottom: 24px; transition: color 0.2s; }
  .back:hover { color: var(--accent); }
  .tool-header { margin-bottom: 24px; }
  h1 { font-size: clamp(24px, 4vw, 36px); font-weight: 700; margin: 10px 0 12px; }
  .sub { color: var(--text2); max-width: 600px; font-size: 15px; line-height: 1.7; }

  /* Input grid */
  .input-grid { display: grid; grid-template-columns: 1fr 340px; gap: 20px; margin-bottom: 20px; align-items: start; }
