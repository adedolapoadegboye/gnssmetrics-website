---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="GNSS Analyzer">
  <div class="toolbar">
    <a href="/tools" class="back">← All tools</a>
    <div class="tool-info">
      <span class="tool-name">GNSS Analyzer</span>
      <span class="version-badge">v3.0</span>
    </div>
    <a href="/public/gnss-analyzer.html" target="_blank" class="open-new">Open in new tab ↗</a>
  </div>
  <div class="frame-wrap">
    <iframe src="/gnss-analyzer.html" title="GNSS Analyzer v3.0" scrolling="yes"></iframe>
  </div>
</Layout>

<style>
  .toolbar {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 10px 24px;
    background: var(--bg2);
    border-bottom: 1px solid var(--border);
  }
  .back { font-size: 13px; color: var(--text2); white-space: nowrap; }
  .back:hover { color: var(--accent); }
  .tool-info { display: flex; align-items: center; gap: 10px; flex: 1; }
  .tool-name { font-size: 14px; font-weight: 600; }
  .version-badge {
    font-size: 10px; font-weight: 600; font-family: var(--mono);
    background: rgba(0,212,170,0.12); color: var(--accent);
    padding: 2px 8px; border-radius: 4px;
  }
  .open-new { font-size: 12px; color: var(--text2); white-space: nowrap; }
  .open-new:hover { color: var(--accent2); }
  .frame-wrap {
    width: 100%;
    height: calc(100vh - 60px - 41px);
    overflow-x: auto;
    overflow-y: hidden;
  }
  iframe {
    width: 100%;
    min-width: 900px;
    height: 100%;
    border: none;
    display: block;
    scrolling: yes;
  }
</style>
