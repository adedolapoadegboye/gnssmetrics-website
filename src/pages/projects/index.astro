---
import Layout from '../../layouts/Layout.astro';
const projects = [
  { href: '/projects/position-resolver', icon: '🛰️', title: 'GNSS Position Resolver', lang: 'C', status: 'Planned', desc: 'Parse RTCM3 messages from a GNSS receiver and compute a position solution from raw pseudorange observables.' },
  { href: '/projects/least-squares', icon: '📐', title: 'Weighted Least Squares Positioning', lang: 'C', status: 'Planned', desc: 'Elevation-weighted position estimation with RAIM fault detection and exclusion.' },
  { href: '/projects/rtk-engine', icon: '📍', title: 'RTK Positioning Engine', lang: 'C++', status: 'Planned', desc: 'Carrier phase double-differencing with LAMBDA integer ambiguity resolution for centimetre-level positioning.' },
  { href: '/projects/sensor-fusion', icon: '🔄', title: 'IMU + GNSS Sensor Fusion', lang: 'C++', status: 'Planned', desc: 'Loosely coupled INS/GNSS integration using an Extended Kalman Filter for positioning through GNSS outages.' },
];
const statusColor = { 'Complete': '#00d4aa', 'In progress': '#f0a500', 'Planned': '#8b91a8' };
---
<Layout title="Projects">
  <section class="section">
    <div class="container">
      <span class="badge">Projects</span>
      <h1>Algorithmic GNSS Projects</h1>
      <p class="sub">Open-source GNSS positioning algorithm implementations. Built from scratch, documented from concept to code.</p>
      <div class="cards-grid">
        {projects.map(p => (
          <a href={p.href} class="card">
            <div class="card-top">
              <span class="card-icon">{p.icon}</span>
              <div class="card-meta">
                <span class="lang-badge">{p.lang}</span>
                <span class="status-badge" style={`color: ${statusColor[p.status]}`}>{p.status}</span>
              </div>
            </div>
            <h3>{p.title}</h3>
            <p>{p.desc}</p>
            <span class="card-link">View project →</span>
          </a>
        ))}
      </div>
    </div>
  </section>
</Layout>
<style>
  h1 { font-size: 36px; font-weight: 700; margin: 12px 0; }
  .sub { color: var(--text2); margin-bottom: 40px; max-width: 560px; }
  .cards-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px; }
  .card { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 28px; display: flex; flex-direction: column; gap: 10px; transition: border-color 0.2s; }
  .card:hover { border-color: rgba(0,212,170,0.3); }
  .card-top { display: flex; justify-content: space-between; align-items: flex-start; }
  .card-icon { font-size: 28px; }
  .card-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 4px; }
  .lang-badge { font-size: 11px; font-weight: 600; font-family: var(--mono); background: rgba(0,153,255,0.12); color: var(--accent2); padding: 2px 8px; border-radius: 4px; }
  .status-badge { font-size: 11px; font-weight: 500; }
  .card h3 { font-size: 17px; font-weight: 600; }
  .card p { font-size: 14px; color: var(--text2); flex: 1; }
  .card-link { font-size: 13px; color: var(--accent); }
</style>
