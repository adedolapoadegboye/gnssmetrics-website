  .eb-row:last-child { border-bottom:none; }
  .eb-header { font-size:10px; font-weight:600; text-transform:uppercase; color:var(--text3); font-family:var(--mono); background:var(--bg3); }
  .eb-bad { color:#ff4757; font-family:var(--mono); font-size:12px; }
  .eb-warn { color:#fbbf24; font-family:var(--mono); font-size:12px; }
  .eb-ok { color:var(--accent); font-family:var(--mono); font-size:12px; }
  .eb-no { color:#ff4757; font-size:12px; }
  .eb-yes { color:var(--accent); font-size:12px; }
  .eb-insight { font-size:13px; color:var(--text2); line-height:1.7; padding:14px 16px; border-top:1px solid var(--border); background:rgba(0,212,170,0.03); }

