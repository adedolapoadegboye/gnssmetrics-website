  @media (max-width:900px) {
    .improvements-grid { grid-template-columns:repeat(2,1fr); }
    .perf-grid { grid-template-columns:repeat(2,1fr); }
    .files-grid { grid-template-columns:repeat(2,1fr); }
    .eb-row { grid-template-columns:1fr 1fr; }
    .eb-row span:nth-child(3), .eb-row span:last-child { display:none; }
  }
  @media (max-width:600px) {
    .improvements-grid { grid-template-columns:1fr; }
    .perf-grid { grid-template-columns:1fr 1fr; }
    .files-grid { grid-template-columns:1fr 1fr; }
    .pipeline-head { align-items:flex-start; }
    .pipeline-hint { white-space:normal; }
    .pipeline-controls { width:100%; justify-content:flex-start; }
    .pipeline-scroll::before, .pipeline-scroll::after { display:none; }
    .pipeline-steps { flex-direction:column; overflow-x:visible; padding:0; cursor:default; }
    .ps-arrow { transform:rotate(90deg); align-self:center; }
    .pt-row { grid-template-columns:1fr; }
    .pipeline-io { grid-template-columns:1fr; }
  }
</style>
<script>
  const pipelineRegion = document.querySelector('[data-pipeline-scroll-region]');
  const pipelineSteps = pipelineRegion?.querySelector('.pipeline-steps');
  const pipelineButtons = document.querySelectorAll('[data-pipeline-scroll]');

  pipelineButtons.forEach((button) => {
    button.addEventListener('click', () => {
      if (!pipelineSteps) return;
      const direction = button.getAttribute('data-pipeline-scroll') === 'left' ? -1 : 1;
      pipelineSteps.scrollBy({ left: direction * 220, behavior: 'smooth' });
    });
  });
</script>
