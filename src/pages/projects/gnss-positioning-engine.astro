  .pt-header { font-size:10px; font-weight:600; text-transform:uppercase; color:var(--text3); font-family:var(--mono); background:var(--bg3); }
  .pt-gain { font-family:var(--mono); color:var(--accent); font-size:12px; }

  /* Source files */
  .files-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:8px; margin-bottom:28px; }
  .file-card { background:var(--bg2); border:1px solid var(--border); border-radius:8px; padding:12px; }
