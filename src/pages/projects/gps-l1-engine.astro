    .pipeline-head { align-items:flex-start; }
    .pipeline-hint { white-space:normal; }
    .pipeline-controls { width:100%; justify-content:flex-start; }
    .pipeline-scroll::before, .pipeline-scroll::after { display:none; }
    .pipeline-steps { flex-direction:column; overflow-x:visible; padding:0; cursor:default; }
