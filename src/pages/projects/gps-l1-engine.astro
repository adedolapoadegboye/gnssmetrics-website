</style>
<script>
  const pipelineRegion = document.querySelector('[data-pipeline-scroll-region]');
  const pipelineSteps = pipelineRegion?.querySelector('.pipeline-steps');
  const pipelineButtons = document.querySelectorAll('[data-pipeline-scroll]');

  pipelineButtons.forEach((button) => {
    button.addEventListener('click', () => {
      if (!pipelineSteps) return;
      const direction = button.getAttribute('data-pipeline-scroll') === 'left' ? -1 : 1;
      pipelineSteps.scrollBy({ left: direction * 220, behavior: 'smooth' });
    });
  });
</script>
