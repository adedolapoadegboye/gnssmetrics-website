---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="GPS L1 Only Position Engine">
  <section class="section">
    <div class="container">

      <a href="/projects" class="back">← All projects</a>

      <div class="project-header">
        <div class="project-meta">
          <span class="lang-badge lang-c">C</span>
          <span class="status-badge status-live">Complete — v2 EKF Edition</span>
        </div>
        <h1>GPS L1 Only Position Engine</h1>
        <p class="sub">
          A complete single-frequency GPS positioning pipeline in portable C11 —
          from raw RINEX observation files to latitude, longitude and height,
          with a 4-state Extended Kalman Filter, Hatch carrier-phase smoothing,
          SNR weighting, elevation masking and a RAIM innovation gate.
        </p>
        <div class="project-links">
          <a href="https://github.com/adedolapoadegboye/GPS_L1_Only_Resolver" target="_blank" rel="noopener noreferrer" class="gh-link">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/></svg>
            View on GitHub
          </a>
          <a href="https://gnssmetrics.com/learn/mathematics/kalman-filter" class="doc-link">Kalman filter background →</a>
          <a href="https://gnssmetrics.com/learn/positioning/standalone-gnss" class="doc-link">Standalone GNSS →</a>
        </div>
      </div>

      <!-- PIPELINE OVERVIEW -->
      <div class="pipeline-card">
        <div class="pipeline-head">
          <div class="pipeline-title-wrap">
            <div class="pipeline-title">Pipeline architecture</div>
            <div class="pipeline-hint">Scroll sideways to follow the processing chain</div>
          </div>
          <div class="pipeline-controls" aria-label="Pipeline navigation">
            <button type="button" class="pipeline-btn" data-pipeline-scroll="left" aria-label="Scroll pipeline left">←</button>
            <button type="button" class="pipeline-btn" data-pipeline-scroll="right" aria-label="Scroll pipeline right">→</button>
          </div>
        </div>
        <div class="pipeline-scroll" data-pipeline-scroll-region>
          <div class="pipeline-steps">
            <div class="ps-step">
              <div class="ps-num">1</div>
              <div class="ps-body">
                <div class="ps-name">RINEX Parser</div>
                <div class="ps-desc">Reads RINEX 2.11 observation file — C1 pseudoranges and L1 carrier phase per epoch</div>
              </div>
            </div>
            <div class="ps-arrow">→</div>
            <div class="ps-step">
              <div class="ps-num">2</div>
              <div class="ps-body">
                <div class="ps-name">Nav Parser + Orbit</div>
                <div class="ps-desc">Parses broadcast ephemeris; computes satellite ECEF positions via IS-GPS-200 algorithm</div>
              </div>
            </div>
            <div class="ps-arrow">→</div>
            <div class="ps-step">
              <div class="ps-num">3</div>
              <div class="ps-body">
                <div class="ps-name">Corrections</div>
                <div class="ps-desc">Satellite clock, Klobuchar ionosphere, Saastamoinen troposphere</div>
              </div>
            </div>
            <div class="ps-arrow">→</div>
            <div class="ps-step ps-solver">
              <div class="ps-num">4</div>
              <div class="ps-body">
                <div class="ps-name">WLS seed → EKF</div>
                <div class="ps-desc">Epoch 0: WLS cold start. Epochs 1–N: 4-state EKF predict + sequential update</div>
              </div>
            </div>
            <div class="ps-arrow">→</div>
            <div class="ps-step">
              <div class="ps-num">5</div>
              <div class="ps-body">
                <div class="ps-name">ECEF → LLH + DOP</div>
                <div class="ps-desc">Bowring iteration for geodetic coordinates; HDOP / VDOP / PDOP from design matrix</div>
              </div>
            </div>
          </div>
        </div>
        <div class="pipeline-io">
          <div class="pio-in">
            <div class="pio-label">Input</div>
            <div class="pio-val"><code>york092b.26o</code> — RINEX 2.11 observations</div>
            <div class="pio-val"><code>brdc0920.26n</code> — Broadcast navigation</div>
          </div>
          <div class="pio-out">
            <div class="pio-label">Output</div>
            <div class="pio-val"><code>positions.csv</code> — per-epoch lat / lon / height / DOP</div>
            <div class="pio-val"><code>summary.csv</code> — aggregate statistics</div>
          </div>
        </div>
      </div>

      <!-- ACCURACY IMPROVEMENTS -->
      <h2>Accuracy improvements</h2>
      <div class="improvements-grid">
        <div class="imp-card">
          <div class="imp-label">A</div>
          <div class="imp-body">
            <div class="imp-name">Hatch filter (N = 500)</div>
            <div class="imp-desc">Carrier-phase smoothing of code pseudoranges. Reduces code noise from ~2 m raw to ~0.05 m after 500 epochs.</div>
            <div class="imp-file">src/hatch.c</div>
          </div>
        </div>
        <div class="imp-card">
          <div class="imp-label">B</div>
          <div class="imp-body">
            <div class="imp-name">SNR-based weighting</div>
            <div class="imp-desc">WLS and EKF measurement noise σᵢ² ∝ 1/SNR². Satellites with weak signals have proportionally less influence on the solution.</div>
            <div class="imp-file">src/main.c</div>
          </div>
        </div>
        <div class="imp-card">
          <div class="imp-label">C</div>
          <div class="imp-body">
            <div class="imp-name">15° elevation mask</div>
            <div class="imp-desc">Rejects near-horizon satellites where ionospheric delay (mapping function ×3–5) and multipath are largest.</div>
            <div class="imp-file">src/main.c</div>
          </div>
        </div>
        <div class="imp-card">
          <div class="imp-label">D</div>
          <div class="imp-body">
            <div class="imp-name">4-state EKF</div>
            <div class="imp-desc">State vector [x, y, z, cδt]. Clock bias propagated as a random walk between epochs rather than re-estimated from scratch each time.</div>
            <div class="imp-file">src/kalman.c</div>
          </div>
        </div>
        <div class="imp-card">
          <div class="imp-label">E</div>
          <div class="imp-body">
            <div class="imp-name">RAIM innovation gate</div>
            <div class="imp-desc">Per-measurement chi-squared test at 4σ. Innovations exceeding the gate are rejected before they can corrupt the filter state.</div>
            <div class="imp-file">src/kalman.c</div>
          </div>
        </div>
        <div class="imp-card">
          <div class="imp-label">F</div>
          <div class="imp-body">
            <div class="imp-name">Position and clock feedback</div>
            <div class="imp-desc">Previous epoch EKF state seeds the next predict step, giving the filter continuity rather than cold-starting every epoch.</div>
            <div class="imp-file">src/main.c</div>
          </div>
        </div>
      </div>

      <!-- PERFORMANCE -->
      <h2>Performance — York dataset</h2>
      <p class="section-sub">
        Dataset: <code>york092b.26o</code> + <code>brdc0920.26n</code> ·
        York, Pennsylvania USA · 2 April 2026 · 3,600 epochs at 1 Hz · GPS-only L1
      </p>

      <div class="perf-grid">
        <div class="perf-card">
          <div class="perf-val">50.8 m</div>
          <div class="perf-label">Horizontal 1σ</div>
          <div class="perf-note">EKF + Hatch. Dominated by unmodelled Klobuchar iono residual.</div>
        </div>
        <div class="perf-card">
          <div class="perf-val">83.1 m</div>
          <div class="perf-label">Vertical 1σ</div>
          <div class="perf-note">Height-clock correlation and iono residual hitting vertical 2–3× harder than horizontal.</div>
        </div>
        <div class="perf-card perf-highlight">
          <div class="perf-val">~50%</div>
          <div class="perf-label">RMS residual reduction</div>
          <div class="perf-note">EKF edition vs. original WLS-only engine. Innovation RMS: 171 m → 85 m.</div>
        </div>
        <div class="perf-card">
          <div class="perf-val">0.05 m</div>
          <div class="perf-label">Code noise after Hatch</div>
          <div class="perf-note">Down from ~2 m raw C/A pseudorange noise after 500-epoch filter convergence.</div>
        </div>
      </div>

      <!-- ERROR BUDGET -->
      <div class="error-budget">
        <div class="eb-title">Error budget — why L1-only has a fundamental floor</div>
        <div class="eb-table">
          <div class="eb-row eb-header">
            <span>Error source</span>
            <span>Typical magnitude</span>
            <span>Type</span>
            <span>Reducible by EKF / Hatch?</span>
          </div>
          <div class="eb-row">
            <span>Unmodelled iono residual</span>
            <span class="eb-bad">5–50 m slant</span>
            <span>Systematic, time-correlated</span>
            <span class="eb-no">No — needs dual-frequency</span>
          </div>
          <div class="eb-row">
            <span>Broadcast clock error</span>
            <span class="eb-warn">~1 m</span>
            <span>Systematic, quasi-static</span>
            <span class="eb-no">No — needs precise ephemeris</span>
          </div>
          <div class="eb-row">
            <span>Tropospheric model residual</span>
            <span class="eb-warn">0.1–1 m</span>
            <span>Systematic, slow-varying</span>
            <span class="eb-no">No</span>
          </div>
          <div class="eb-row">
            <span>Code pseudorange noise (C/A)</span>
            <span class="eb-ok">~2 m raw → 0.05 m Hatch</span>
            <span>Random, independent</span>
            <span class="eb-yes">Yes — Hatch filter</span>
          </div>
          <div class="eb-row">
            <span>Receiver thermal noise</span>
            <span class="eb-ok">~0.1 m</span>
            <span>Random, independent</span>
            <span class="eb-yes">Yes — EKF averaging</span>
          </div>
          <div class="eb-row">
            <span>Multipath</span>
            <span class="eb-warn">0.5–5 m</span>
            <span>Semi-systematic</span>
            <span class="eb-partial">Partially — RAIM gate</span>
          </div>
        </div>
        <div class="eb-insight">
          The key insight: GPS pseudorange errors are dominated by systematic, time-correlated biases —
          the exact opposite of what a Kalman filter is designed to handle.
          Getting below the ~50 m horizontal floor requires dual-frequency iono removal, SBAS corrections or PPP.
        </div>
      </div>

      <!-- PATH TO BETTER ACCURACY -->
      <h2>Path to better accuracy</h2>
      <div class="path-table">
        <div class="pt-row pt-header">
          <span>Technique</span>
          <span>Expected improvement (from 50.8 m H 1σ)</span>
        </div>
        <div class="pt-row">
          <span>Dual-frequency iono removal (L1/L2 or L1/L5)</span>
          <span class="pt-gain">Horizontal ~5–15 m</span>
        </div>
        <div class="pt-row">
          <span>SBAS corrections (WAAS / EGNOS)</span>
          <span class="pt-gain">Horizontal ~1–5 m</span>
        </div>
        <div class="pt-row">
          <span>Precise Point Positioning (PPP)</span>
          <span class="pt-gain">Horizontal ~0.1 m after 20–30 min convergence</span>
        </div>
        <div class="pt-row">
          <span>Carrier-phase ambiguity fixing (RTK)</span>
          <span class="pt-gain">Horizontal ~0.01–0.05 m after fixing</span>
        </div>
        <div class="pt-row">
          <span>Multi-constellation (GPS + GLONASS + Galileo)</span>
          <span class="pt-gain">~20% improvement via better geometry</span>
        </div>
        <div class="pt-row">
          <span>RTS backward smoother (offline)</span>
          <span class="pt-gain">~30–40% noise reduction on position</span>
        </div>
      </div>

      <!-- BUILD -->
      <h2>Build and run</h2>
      <div class="code-block">
        <div class="cb-header">Bash — requires GCC and libm</div>
        <pre><code>git clone https://github.com/adedolapoadegboye/GPS_L1_Only_Resolver
cd GPS_L1_Only_Resolver

make run        # build with -O2 and run immediately
make debug      # build with -g3 -fsanitize=address,undefined
make rebuild    # clean rebuild

# Generate plots (requires Python 3 + matplotlib)
python3 results/plot_results.py</code></pre>
      </div>

      <!-- PROJECT FILES -->
      <h2>Source files</h2>
      <div class="files-grid">
        <div class="file-card"><div class="file-name">main.c</div><div class="file-desc">Pipeline orchestration — WLS seed, EKF epoch loop, SNR weighting, elevation mask</div></div>
        <div class="file-card"><div class="file-name">kalman.c</div><div class="file-desc">4-state EKF — predict, sequential measurement update, RAIM innovation gate</div></div>
        <div class="file-card"><div class="file-name">hatch.c</div><div class="file-desc">Hatch carrier-phase smoothing filter (N = 500)</div></div>
        <div class="file-card"><div class="file-name">sat_pos.c</div><div class="file-desc">IS-GPS-200 satellite orbit model — Keplerian elements + perturbations</div></div>
        <div class="file-card"><div class="file-name">corrections.c</div><div class="file-desc">Satellite clock polynomial, Klobuchar iono, Saastamoinen tropo, ECEF → LLH</div></div>
        <div class="file-card"><div class="file-name">solver.c</div><div class="file-desc">Weighted Least-Squares position solver and DOP computation (epoch 0 cold start)</div></div>
        <div class="file-card"><div class="file-name">rinex.c</div><div class="file-desc">RINEX 2.11 observation file parser</div></div>
        <div class="file-card"><div class="file-name">nav.c</div><div class="file-desc">RINEX 2.11 navigation (broadcast ephemeris) file parser</div></div>
      </div>

      <!-- GITHUB FOOTER -->
      <div class="gh-footer">
        <div class="ghf-left">
          <div class="ghf-title">GPS L1 Only Position Engine</div>
          <div class="ghf-sub">C11 · No external dependencies · MIT licence</div>
        </div>
        <a href="https://github.com/adedolapoadegboye/GPS_L1_Only_Resolver" target="_blank" rel="noopener noreferrer" class="ghf-btn">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.342-3.369-1.342-.454-1.155-1.11-1.462-1.11-1.462-.908-.62.069-.608.069-.608 1.003.07 1.531 1.03 1.531 1.03.892 1.529 2.341 1.087 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.578 9.578 0 0112 6.836a9.59 9.59 0 012.504.337c1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.202 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.578.688.48C19.138 20.161 22 16.416 22 12c0-5.523-4.477-10-10-10z"/></svg>
          View source on GitHub
        </a>
      </div>

    </div>
  </section>
</Layout>

<style>
  .back { font-size:13px; color:var(--text2); display:inline-block; margin-bottom:24px; transition:color 0.2s; }
  .back:hover { color:var(--accent); }

  .project-header { margin-bottom:36px; }
  .project-meta { display:flex; gap:10px; align-items:center; margin-bottom:14px; flex-wrap:wrap; }
  h1 { font-size:clamp(26px,4vw,40px); font-weight:700; margin-bottom:14px; line-height:1.15; }
  h2 { font-size:20px; font-weight:700; margin:36px 0 14px; padding-top:8px; border-top:1px solid var(--border); }
  .sub { color:var(--text2); max-width:680px; font-size:16px; line-height:1.8; margin-bottom:20px; }
  .section-sub { font-size:13px; color:var(--text3); margin-bottom:14px; font-family:var(--mono); }
  p { font-size:15px; color:var(--text2); line-height:1.8; margin-bottom:14px; }
  code { font-family:var(--mono); font-size:12px; background:var(--bg3); padding:1px 5px; border-radius:3px; color:var(--accent2); }

  .lang-badge { font-size:11px; font-weight:700; font-family:var(--mono); padding:3px 10px; border-radius:4px; }
  .lang-c { background:rgba(0,153,255,0.12); color:var(--accent2); }
  .status-badge { font-size:12px; font-weight:600; }
  .status-live { color:var(--accent); }

  .project-links { display:flex; gap:12px; flex-wrap:wrap; align-items:center; }
  .gh-link { display:flex; align-items:center; gap:7px; font-size:13px; font-weight:600; color:var(--text); background:var(--bg2); border:1px solid var(--border); padding:7px 14px; border-radius:7px; transition:border-color 0.2s; }
  .gh-link:hover { border-color:rgba(0,212,170,0.4); color:var(--accent); }
  .doc-link { font-size:13px; color:var(--accent2); text-decoration:underline; text-underline-offset:2px; }

  /* Pipeline */
  .pipeline-card { background:var(--bg2); border:1px solid var(--border); border-radius:12px; padding:22px; margin-bottom:28px; }
  .pipeline-head { display:flex; align-items:center; justify-content:space-between; gap:16px; margin-bottom:16px; flex-wrap:wrap; }
  .pipeline-title-wrap { display:flex; flex-direction:column; gap:6px; }
  .pipeline-title { font-size:11px; font-weight:700; text-transform:uppercase; letter-spacing:0.1em; color:var(--accent); font-family:var(--mono); margin:0; }
  .pipeline-hint { font-size:11px; color:var(--text3); font-family:var(--mono); white-space:nowrap; }
  .pipeline-controls { display:flex; align-items:center; gap:8px; }
  .pipeline-btn { width:34px; height:34px; border-radius:999px; border:1px solid var(--border); background:var(--bg3); color:var(--accent); font-size:15px; font-weight:700; display:flex; align-items:center; justify-content:center; transition:border-color 0.2s, background 0.2s, color 0.2s, transform 0.2s; }
  .pipeline-btn:hover { border-color:rgba(0,212,170,0.35); background:rgba(0,212,170,0.08); transform:translateY(-1px); }
  .pipeline-scroll { position:relative; margin:0 -6px 16px; padding:0 6px 10px; }
  .pipeline-scroll::before, .pipeline-scroll::after { content:''; position:absolute; top:0; bottom:10px; width:28px; pointer-events:none; z-index:1; }
  .pipeline-scroll::before { left:0; background:linear-gradient(90deg, var(--bg2) 15%, rgba(15,18,24,0)); }
  .pipeline-scroll::after { right:0; background:linear-gradient(270deg, var(--bg2) 15%, rgba(15,18,24,0)); }
  .pipeline-steps { display:flex; align-items:flex-start; gap:6px; overflow-x:auto; padding:2px 4px 10px; margin:0; scrollbar-width:thin; scrollbar-color:rgba(0,212,170,0.45) rgba(255,255,255,0.05); cursor:grab; scroll-padding-inline:4px; }
  .pipeline-steps::-webkit-scrollbar { height:10px; }
  .pipeline-steps::-webkit-scrollbar-track { background:rgba(255,255,255,0.05); border-radius:999px; }
  .pipeline-steps::-webkit-scrollbar-thumb { background:linear-gradient(90deg, rgba(0,212,170,0.35), rgba(0,153,255,0.35)); border-radius:999px; border:2px solid rgba(8,10,14,0.35); }
  .pipeline-steps:active { cursor:grabbing; }
  .ps-step { background:var(--bg3); border:1px solid var(--border); border-radius:8px; padding:12px; min-width:150px; flex-shrink:0; display:flex; gap:10px; }
  .ps-solver { border-color:rgba(0,212,170,0.3); background:rgba(0,212,170,0.04); }
  .ps-num { width:22px; height:22px; background:rgba(0,212,170,0.12); color:var(--accent); border-radius:50%; font-size:10px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-family:var(--mono); }
  .ps-name { font-size:12px; font-weight:600; color:var(--text); margin-bottom:3px; }
  .ps-desc { font-size:11px; color:var(--text3); line-height:1.5; }
  .ps-arrow { font-size:16px; color:var(--text3); padding-top:14px; flex-shrink:0; }
  .pipeline-io { display:grid; grid-template-columns:1fr 1fr; gap:12px; padding-top:14px; border-top:1px solid var(--border); }
  .pio-label { font-size:10px; font-weight:700; text-transform:uppercase; color:var(--text3); font-family:var(--mono); margin-bottom:6px; }
  .pio-val { font-size:12px; color:var(--text2); margin-bottom:3px; }

  /* Improvements */
  .improvements-grid { display:grid; grid-template-columns:repeat(3,1fr); gap:10px; margin-bottom:8px; }
  .imp-card { background:var(--bg2); border:1px solid var(--border); border-radius:10px; padding:16px; display:flex; gap:12px; }
  .imp-label { width:26px; height:26px; background:rgba(0,212,170,0.12); color:var(--accent); border-radius:6px; font-size:12px; font-weight:700; display:flex; align-items:center; justify-content:center; flex-shrink:0; font-family:var(--mono); }
  .imp-name { font-size:13px; font-weight:600; color:var(--text); margin-bottom:4px; }
  .imp-desc { font-size:12px; color:var(--text3); line-height:1.6; margin-bottom:6px; }
  .imp-file { font-size:10px; font-family:var(--mono); color:var(--accent2); }

  /* Performance */
  .perf-grid { display:grid; grid-template-columns:repeat(4,1fr); gap:12px; margin-bottom:20px; }
  .perf-card { background:var(--bg2); border:1px solid var(--border); border-radius:10px; padding:18px; text-align:center; }
  .perf-highlight { border-color:rgba(0,212,170,0.3); }
  .perf-val { font-size:26px; font-weight:700; font-family:var(--mono); color:var(--accent); margin-bottom:6px; }
  .perf-label { font-size:12px; font-weight:600; color:var(--text); margin-bottom:6px; }
  .perf-note { font-size:11px; color:var(--text3); line-height:1.5; }

  /* Error budget */
