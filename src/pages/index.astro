---
import Layout from '../layouts/Layout.astro';
---
<Layout title="Community GNSS Platform">

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <span class="badge">Open · Vendor-neutral · Community-driven</span>
      <h1>The GNSS knowledge platform<br class="hero-br"/> built by engineers, for engineers</h1>
      <p class="hero-sub">
        Tools, live dashboards, educational resources, algorithmic projects and curated news —
        everything a GNSS engineer needs in one place.
      </p>
      <div class="hero-actions">
        <a href="/tools" class="btn-primary">Open GNSS Analyzer</a>
        <a href="/learn" class="btn-secondary">Start learning</a>
      </div>
    </div>
  </section>

  <!-- SECTIONS GRID -->
  <section class="section">
    <div class="container">
      <div class="cards-grid">

        <a href="/tools" class="card">
          <div class="card-icon">⚙️</div>
          <h3>Tools</h3>
          <p>Browser-based GNSS analysis — NMEA, RINEX, RTK alignment, Quectel PQTM. No install. No data leaves your device.</p>
          <span class="card-link">Open tools →</span>
        </a>

        <a href="/dashboards" class="card">
          <div class="card-icon">🌐</div>
          <h3>Dashboards</h3>
          <p>Live ionospheric conditions, jamming activity, space weather alerts and constellation health — all from public data sources.</p>
          <span class="card-link">View dashboards →</span>
        </a>

        <a href="/learn" class="card">
          <div class="card-icon">📡</div>
          <h3>Learn</h3>
          <p>GNSS fundamentals, positioning mathematics, protocol references, and structured guides from first principles to advanced topics.</p>
          <span class="card-link">Start learning →</span>
        </a>

        <a href="/projects" class="card">
          <div class="card-icon">🛠️</div>
          <h3>Projects</h3>
          <p>Open-source GNSS algorithm implementations — position resolver, RTK engine, IMU fusion. Documented from concept to code.</p>
          <span class="card-link">View projects →</span>
        </a>

        <a href="/blog" class="card">
          <div class="card-icon">✍️</div>
          <h3>Blog</h3>
          <p>Technical articles, field notes, evaluations and tutorials written by practitioners working with GNSS hardware daily.</p>
          <span class="card-link">Read articles →</span>
        </a>

        <a href="/news" class="card">
          <div class="card-icon">📰</div>
          <h3>News</h3>
          <p>Curated GNSS industry and academic news — new constellations, corrections services, research and product releases.</p>
          <span class="card-link">Latest news →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter-section">
    <div class="container">
      <div class="newsletter-box">
        <div class="newsletter-icon">📬</div>
        <h2>Stay current with GNSS</h2>
        <p>Weekly digest — curated news, new tools, project updates. No spam. Unsubscribe any time.</p>

        <form
          action="https://buttondown.email/api/emails/embed-subscribe/gnssmetrics"
          method="post"
          class="newsletter-form"
          id="newsletterForm"
        >
          <input
            type="email"
            name="email"
            placeholder="your@email.com"
            required
          />
          <button type="submit" id="subscribeBtn">Subscribe</button>
        </form>

        <div class="newsletter-success" id="newsletterSuccess">
          ✅ You're subscribed! Check your inbox for a confirmation email.
          <button class="newsletter-reset" id="resetBtn">Subscribe another email</button>
        </div>

        <div class="newsletter-duplicate" id="newsletterDuplicate">
          ℹ️ That email is already subscribed. Check your inbox for past issues.
          <button class="newsletter-reset" id="resetBtn2">Try another email</button>
        </div>

        <p class="newsletter-note">
          Powered by <a href="https://buttondown.email" target="_blank" rel="noopener noreferrer">Buttondown</a>.
          Free. Cancel any time.
        </p>
      </div>
    </div>
  </section>

</Layout>

<script>
  const form = document.getElementById('newsletterForm');
  const success = document.getElementById('newsletterSuccess');
  const duplicate = document.getElementById('newsletterDuplicate');
  const btn = document.getElementById('subscribeBtn');

  function resetForm() {
    form.style.display = 'flex';
    success.style.display = 'none';
    duplicate.style.display = 'none';
    form.reset();
  }

  document.getElementById('resetBtn').addEventListener('click', resetForm);
  document.getElementById('resetBtn2').addEventListener('click', resetForm);

  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = form.querySelector('input[type="email"]').value;
    let status = 200;

    // Show loading state
    btn.textContent = 'Subscribing...';
    btn.disabled = true;
    btn.style.opacity = '0.7';

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
        body: new URLSearchParams({ email }),
      });
      status = res.status;
    } catch (err) {
      // Buttondown blocks CORS so fetch will throw — subscription still
      // goes through on their end, safe to treat as success
    }

    // Reset button before hiding form
    btn.textContent = 'Subscribe';
    btn.disabled = false;
    btn.style.opacity = '1';

    form.style.display = 'none';
    if (status === 400) {
      duplicate.style.display = 'block';
    } else {
      success.style.display = 'block';
    }
  });
</script>

<style>
  /* HERO */
  .hero {
    padding: 100px 0 80px;
    border-bottom: 1px solid var(--border);
  }
  .hero .badge { margin-bottom: 24px; display: inline-block; }
  .hero h1 {
    font-size: clamp(28px, 5vw, 54px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .hero-sub {
    font-size: clamp(15px, 2vw, 18px);
    color: var(--text2);
    max-width: 600px;
    margin-bottom: 36px;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  .btn-primary {
    padding: 12px 28px; border-radius: 8px;
    background: var(--accent); color: #0d0f14;
    font-weight: 600; font-size: 14px;
    transition: opacity 0.2s; white-space: nowrap;
  }
  .btn-primary:hover { opacity: 0.88; }

  .btn-secondary {
    padding: 12px 28px; border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--text2); font-size: 14px;
    transition: all 0.2s; white-space: nowrap;
  }
  .btn-secondary:hover { border-color: var(--text2); color: var(--text); }

  /* CARDS */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    transition: border-color 0.2s, transform 0.2s;
    display: flex; flex-direction: column; gap: 10px;
  }
  .card:hover { border-color: rgba(0,212,170,0.3); transform: translateY(-2px); }
  .card-icon { font-size: 28px; }
  .card h3 { font-size: 17px; font-weight: 600; }
  .card p { font-size: 14px; color: var(--text2); line-height: 1.6; flex: 1; }
  .card-link { font-size: 13px; color: var(--accent); margin-top: 4px; }

  /* NEWSLETTER */
  .newsletter-section { padding: 80px 0; }
  .newsletter-box {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .newsletter-icon { font-size: 32px; margin-bottom: 16px; }
  .newsletter-box h2 {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700; margin-bottom: 10px;
  }
  .newsletter-box > p {
    color: var(--text2); margin-bottom: 24px; font-size: 15px;
    line-height: 1.6;
  }
  .newsletter-form {
    display: flex; gap: 10px;
    justify-content: center; flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .newsletter-form input {
    padding: 11px 16px; border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg3); color: var(--text);
    font-size: 14px; flex: 1; min-width: 0;
    outline: none; font-family: var(--sans);
  }
  .newsletter-form input:focus { border-color: var(--accent); }
  .newsletter-form button[type="submit"] {
    padding: 11px 24px; border-radius: 8px; border: none;
    background: var(--accent); color: #0d0f14;
    font-weight: 600; font-size: 14px;
    cursor: pointer; white-space: nowrap;
    font-family: var(--sans);
    transition: opacity 0.2s;
  }
  .newsletter-form button[type="submit"]:hover { opacity: 0.88; }

  .newsletter-success {
    display: none;
    font-size: 15px;
    color: var(--accent);
    padding: 16px;
    background: rgba(0,212,170,0.08);
    border: 1px solid rgba(0,212,170,0.2);
    border-radius: 8px;
    margin-bottom: 12px;
  }

  .newsletter-duplicate {
    display: none;
    font-size: 15px;
    color: var(--accent2);
    padding: 16px;
    background: rgba(0,153,255,0.08);
    border: 1px solid rgba(0,153,255,0.2);
    border-radius: 8px;
    margin-bottom: 12px;
  }

  .newsletter-reset {
    display: block;
    margin: 10px auto 0;
    background: none; border: none;
    font-size: 12px; color: var(--text3);
    cursor: pointer; text-decoration: underline;
    text-underline-offset: 2px;
    font-family: var(--sans);
  }
  .newsletter-reset:hover { color: var(--text2); }

  .newsletter-note {
    font-size: 12px; color: var(--text2);
    opacity: 0.6; line-height: 1.6;
  }
  .newsletter-note a {
    color: var(--text2); text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero { padding: 60px 0 48px; }
    .hero-br { display: none; }
    .newsletter-box { padding: 32px 24px; }
  }

  @media (max-width: 560px) {
    .cards-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; }
    .btn-primary, .btn-secondary { text-align: center; }
    .newsletter-form { flex-direction: column; }
    .newsletter-form input, .newsletter-form button { width: 100%; }
  }
</style>