---
import Layout from '../layouts/Layout.astro';
---
<Layout title="GNSS Metrics: A Community-based GNSS Platform">

  <!-- HERO -->
  <section class="hero">
    <div class="container">
      <span class="badge">Open · Educative · Community-driven</span>
      <h1>The GNSS knowledge platform<br class="hero-br"/> built by engineers, for engineers</h1>
      <p class="hero-sub">
        Tools, live dashboards, educational resources, algorithmic projects and curated news —
        everything a GNSS engineer needs in one place.
      </p>
      <div class="hero-actions">
        <a href="/tools" class="btn-primary">Open GNSS Analyzer</a>
        <a href="/learn" class="btn-secondary">Start learning</a>
      </div>
    </div>
  </section>

  <!-- SECTIONS GRID -->
  <section class="section">
    <div class="container">
      <div class="cards-grid">

        <a href="/tools" class="card">
          <div class="card-icon">⚙️</div>
          <h3>Tools</h3>
          <p>Browser-based GNSS analysis — NMEA, RINEX, RTK alignment, Quectel PQTM. No install. No data leaves your device.</p>
          <span class="card-link">Open tools →</span>
        </a>

        <a href="/dashboards" class="card">
          <div class="card-icon">🌐</div>
          <h3>Dashboards</h3>
          <p>Live ionospheric conditions, jamming activity, space weather alerts and constellation health — all from public data sources.</p>
          <span class="card-link">View dashboards →</span>
        </a>

        <a href="/learn" class="card">
          <div class="card-icon">📡</div>
          <h3>Learn</h3>
          <p>GNSS fundamentals, positioning mathematics, protocol references, and structured guides from first principles to advanced topics.</p>
          <span class="card-link">Start learning →</span>
        </a>

        <a href="/projects" class="card">
          <div class="card-icon">🛠️</div>
          <h3>Projects</h3>
          <p>Open-source GNSS algorithm implementations — position resolver, RTK engine, IMU fusion. Documented from concept to code.</p>
          <span class="card-link">View projects →</span>
        </a>

        <a href="/blog" class="card">
          <div class="card-icon">✍️</div>
          <h3>Blog</h3>
          <p>Technical articles, field notes, evaluations and tutorials written by practitioners working with GNSS hardware daily.</p>
          <span class="card-link">Read articles →</span>
        </a>

        <a href="/news" class="card">
          <div class="card-icon">📰</div>
          <h3>News</h3>
          <p>Curated GNSS industry and academic news — new constellations, corrections services, research and product releases.</p>
          <span class="card-link">Latest news →</span>
        </a>

      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="newsletter-section">
    <div class="container">
      <div class="newsletter-box">
        <div class="newsletter-icon">📬</div>
        <h2>Stay current with GNSS</h2>
        <p>Weekly digest — curated news, new tools, project updates. No spam. Unsubscribe any time.</p>

        <form
          action="https://buttondown.com/api/emails/embed-subscribe/gnssmetrics"
          method="post"
          class="newsletter-form embeddable-buttondown-form"
        >
          <input
            type="email"
            name="email"
            id="bd-email"
            placeholder="your@email.com"
            required
          />
          <button type="submit">Subscribe</button>
        </form>

        <p class="newsletter-note">
          <a href="https://buttondown.com/refer/gnssmetrics" target="_blank" rel="noopener noreferrer">
            Powered by Buttondown
          </a>
          · Free · Unsubscribe any time.
        </p>
      </div>
    </div>
  </section>

</Layout>

<style>
  /* HERO */
  .hero {
    padding: 100px 0 80px;
    border-bottom: 1px solid var(--border);
  }
  .hero .badge { margin-bottom: 24px; display: inline-block; }
  .hero h1 {
    font-size: clamp(28px, 5vw, 54px);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 20px;
  }
  .hero-sub {
    font-size: clamp(15px, 2vw, 18px);
    color: var(--text2);
    max-width: 600px;
    margin-bottom: 36px;
    line-height: 1.7;
  }
  .hero-actions { display: flex; gap: 12px; flex-wrap: wrap; }

  .btn-primary {
    padding: 12px 28px; border-radius: 8px;
    background: var(--accent); color: #0d0f14;
    font-weight: 600; font-size: 14px;
    transition: opacity 0.2s; white-space: nowrap;
  }
  .btn-primary:hover { opacity: 0.88; }

  .btn-secondary {
    padding: 12px 28px; border-radius: 8px;
    border: 1px solid var(--border);
    color: var(--text2); font-size: 14px;
    transition: all 0.2s; white-space: nowrap;
  }
  .btn-secondary:hover { border-color: var(--text2); color: var(--text); }

  /* CARDS */
  .cards-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }
  .card {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 28px;
    transition: border-color 0.2s, transform 0.2s;
    display: flex; flex-direction: column; gap: 10px;
  }
  .card:hover { border-color: rgba(0,212,170,0.3); transform: translateY(-2px); }
  .card-icon { font-size: 28px; }
  .card h3 { font-size: 17px; font-weight: 600; }
  .card p { font-size: 14px; color: var(--text2); line-height: 1.6; flex: 1; }
  .card-link { font-size: 13px; color: var(--accent); margin-top: 4px; }

  /* NEWSLETTER */
  .newsletter-section { padding: 80px 0; }
  .newsletter-box {
    background: var(--bg2);
    border: 1px solid var(--border);
    border-radius: 16px;
    padding: 48px;
    text-align: center;
    max-width: 560px;
    margin: 0 auto;
  }
  .newsletter-icon { font-size: 32px; margin-bottom: 16px; }
  .newsletter-box h2 {
    font-size: clamp(20px, 3vw, 26px);
    font-weight: 700; margin-bottom: 10px;
  }
  .newsletter-box > p {
    color: var(--text2); margin-bottom: 24px; font-size: 15px;
    line-height: 1.6;
  }
  .newsletter-form {
    display: flex; gap: 10px;
    justify-content: center; flex-wrap: wrap;
    margin-bottom: 12px;
  }
  .newsletter-form input[type="email"] {
    padding: 11px 16px; border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--bg3); color: var(--text);
    font-size: 14px; flex: 1; min-width: 0;
    outline: none; font-family: var(--sans);
  }
  .newsletter-form input[type="email"]:focus { border-color: var(--accent); }
  .newsletter-form button[type="submit"] {
    padding: 11px 24px; border-radius: 8px; border: none;
    background: var(--accent); color: #0d0f14;
    font-weight: 600; font-size: 14px;
    cursor: pointer; white-space: nowrap;
    font-family: var(--sans);
    transition: opacity 0.2s;
  }
  .newsletter-form button[type="submit"]:hover { opacity: 0.88; }

  .newsletter-note {
    font-size: 12px; color: var(--text2);
    opacity: 0.6; line-height: 1.6;
  }
  .newsletter-note a {
    color: var(--text2); text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .cards-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .hero { padding: 60px 0 48px; }
    .hero-br { display: none; }
    .newsletter-box { padding: 32px 24px; }
  }

  @media (max-width: 560px) {
    .cards-grid { grid-template-columns: 1fr; }
    .hero-actions { flex-direction: column; }
    .btn-primary, .btn-secondary { text-align: center; }
    .newsletter-form { flex-direction: column; }
    .newsletter-form input, .newsletter-form button { width: 100%; }
  }
</style>