---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map(article => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

function formatDate(dateStr) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric', timeZone: 'UTC'
  });
}
---
<Layout title={article.data.title}>
  <section class="section">
    <div class="container">

      <a href="/news" class="back">← All news</a>

      <article class="article">

        <!-- Header -->
        <header class="article-header">
          <div class="article-meta">
            <span class="badge-category">Daily Digest</span>
            {article.data.generated && <span class="badge-ai">AI curated</span>}
            <time class="date">{formatDate(article.data.date)}</time>
          </div>

          <h1>{article.data.title}</h1>

          {article.data.tags && article.data.tags.length > 0 && (
            <div class="article-tags">
              {article.data.tags.map(tag => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          )}
        </header>

        <!-- Body -->
        <div class="article-body">
          <Content />
        </div>

        <!-- Sources -->
        {article.data.sources && article.data.sources.length > 0 && (
          <footer class="article-footer">
            <h4>Sources</h4>
            <ul class="sources-list">
              {article.data.sources.map(s => (
                <li>
                  <a href={s} target="_blank" rel="noopener noreferrer">{s}</a>
                </li>
              ))}
            </ul>
            <p class="disclosure">
              This digest was automatically generated by the GNSSMetrics news pipeline using publicly available RSS feeds.
              Content is summarised by AI — always verify with the original sources linked above.
            </p>
          </footer>
        )}

      </article>

      <!-- Nav between articles -->
      <div class="article-nav">
        <a href="/news" class="nav-back">← Back to all news</a>
      </div>

    </div>
  </section>
</Layout>

<style>
  /* Back link */
  .back {
    font-size: 13px; color: var(--text2);
    display: inline-flex; align-items: center; gap: 6px;
    margin-bottom: 32px; transition: color 0.2s;
  }
  .back:hover { color: var(--accent); }

  /* Article wrapper */
  .article { max-width: 720px; }

  /* Header */
  .article-header {
    margin-bottom: 40px;
    padding-bottom: 28px;
    border-bottom: 1px solid var(--border);
  }

  .article-meta {
    display: flex; align-items: center;
    flex-wrap: wrap; gap: 8px;
    margin-bottom: 16px;
  }

  .badge-category {
    font-size: 10px; font-weight: 600;
    padding: 3px 10px; border-radius: 4px;
    background: rgba(0,212,170,0.12);
    color: var(--accent);
    border: 1px solid rgba(0,212,170,0.25);
    letter-spacing: 0.05em; text-transform: uppercase;
  }

  .badge-ai {
    font-size: 10px; padding: 3px 10px; border-radius: 4px;
    background: rgba(0,153,255,0.1); color: var(--accent2);
    border: 1px solid rgba(0,153,255,0.2);
  }

  .date {
    font-size: 12px; color: var(--text3);
    font-family: var(--mono); letter-spacing: 0.04em;
    margin-left: 4px;
  }

  h1 {
    font-size: clamp(22px, 4vw, 34px);
    font-weight: 700; line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-bottom: 16px;
  }

  .article-tags {
    display: flex; flex-wrap: wrap; gap: 8px;
    margin-top: 8px;
  }
  .tag {
    font-size: 11px; color: var(--text3);
    font-family: var(--mono);
  }

  /* Body */
  .article-body {
    font-size: 16px; line-height: 1.85;
    color: var(--text2);
    margin-bottom: 48px;
  }
  .article-body p { margin-bottom: 20px; }
  .article-body p:last-child { margin-bottom: 0; }
  .article-body em {
    color: var(--text3); font-size: 14px;
    font-style: italic; display: block;
    margin-bottom: 20px; line-height: 1.6;
  }
  .article-body strong { color: var(--text); font-weight: 600; }

  /* Footer / sources */
  .article-footer {
    border-top: 1px solid var(--border);
    padding-top: 28px;
    margin-bottom: 40px;
  }
  .article-footer h4 {
    font-size: 11px; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--text3); margin-bottom: 12px;
  }
  .sources-list {
    list-style: none; display: flex;
    flex-direction: column; gap: 6px;
    margin-bottom: 16px;
  }
  .sources-list a {
    font-size: 12px; color: var(--accent2);
    font-family: var(--mono);
    word-break: break-all;
    transition: opacity 0.2s;
  }
  .sources-list a:hover { opacity: 0.75; text-decoration: underline; }

  .disclosure {
    font-size: 11px; color: var(--text3);
    line-height: 1.6; font-style: italic;
    padding: 12px 16px;
    background: var(--bg2);
    border-radius: 6px;
    border-left: 3px solid var(--border);
  }

  /* Bottom nav */
  .article-nav {
    padding-top: 16px;
    border-top: 1px solid var(--border);
  }
  .nav-back {
    font-size: 13px; color: var(--text2);
    transition: color 0.2s;
  }
  .nav-back:hover { color: var(--accent); }

  /* Mobile */
  @media (max-width: 768px) {
    .article-body { font-size: 15px; }
    h1 { font-size: 22px; }
    .article-header { margin-bottom: 28px; padding-bottom: 20px; }
  }
</style>