---
import Layout from '../../layouts/Layout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map(article => ({
    params: { id: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);
---

<Layout title={article.data.title}>
  <section class="section">
    <div class="container">
      <a href="/news" class="back">← All news</a>
      <div class="article-header">
        <div class="article-meta">
          <span class="date">{article.data.date}</span>
          {article.data.generated && <span class="ai-badge">AI curated</span>}
        </div>
        <h1>{article.data.title}</h1>
        {article.data.sources?.length > 0 && (
          <div class="sources">
            <span class="sources-label">Sources:</span>
            {article.data.sources.map(s => (
              <a href={s} target="_blank" rel="noopener noreferrer" class="source-link">{s}</a>
            ))}
          </div>
        )}
      </div>
      <div class="article-body">
        <Content />
      </div>
    </div>
  </section>
</Layout>

<style>
  .back { font-size: 13px; color: var(--text2); display: inline-block; margin-bottom: 24px; }
  .back:hover { color: var(--accent); }
  .article-header { margin-bottom: 40px; border-bottom: 1px solid var(--border); padding-bottom: 24px; }
  .article-meta { display: flex; align-items: center; gap: 12px; margin-bottom: 12px; }
  .date { font-size: 12px; color: var(--text3); font-family: var(--mono); }
  .ai-badge {
    font-size: 10px; padding: 2px 8px;
    background: rgba(0,153,255,0.1); color: var(--accent2);
    border-radius: 4px;
  }
  h1 { font-size: clamp(22px, 4vw, 32px); font-weight: 700; margin-bottom: 16px; line-height: 1.3; }
  .sources { display: flex; flex-wrap: wrap; gap: 8px; align-items: center; margin-top: 12px; }
  .sources-label { font-size: 11px; color: var(--text3); }
  .source-link { font-size: 11px; color: var(--accent2); word-break: break-all; }
  .source-link:hover { text-decoration: underline; }
  .article-body {
    max-width: 680px;
    font-size: 16px; line-height: 1.8; color: var(--text2);
  }
  .article-body p { margin-bottom: 16px; }
  .article-body em { color: var(--text3); font-size: 14px; }
  @media (max-width: 768px) {
    .article-body { font-size: 15px; }
  }
</style>
