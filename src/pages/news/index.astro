---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const sorted = allNews.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
---
<Layout title="News">
  <section class="section">
    <div class="container">
      <span class="badge">News</span>
      <h1>GNSS Industry News</h1>
      <p class="sub">Daily digest curated from public GNSS news sources. Summarised by AI — sources always linked.</p>

      {sorted.length === 0 ? (
        <div class="coming-soon">
          <div class="cs-icon">📰</div>
          <h3>First digest coming tomorrow</h3>
          <p>The automated news pipeline publishes a fresh digest every morning at 06:00 UTC.</p>
        </div>
      ) : (
        <div class="news-list">
          {sorted.map(article => (
            <a href={`/news/${article.id}`} class="news-card">
              <div class="news-date">{article.data.date}</div>
              <h3>{article.data.title}</h3>
              {article.data.generated && (
                <span class="ai-badge">AI curated</span>
              )}
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
  h1 { font-size: 36px; font-weight: 700; margin: 12px 0; }
  .sub { color: var(--text2); margin-bottom: 40px; max-width: 560px; }
  .news-list { display: flex; flex-direction: column; gap: 12px; }
  .news-card {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 10px; padding: 20px 24px;
    display: flex; flex-direction: column; gap: 6px;
    transition: border-color 0.2s;
  }
  .news-card:hover { border-color: rgba(0,212,170,0.3); }
  .news-date { font-size: 11px; color: var(--text3); font-family: var(--mono); }
  .news-card h3 { font-size: 16px; font-weight: 600; color: var(--text); }
  .ai-badge {
    display: inline-block; font-size: 10px; padding: 2px 8px;
    background: rgba(0,153,255,0.1); color: var(--accent2);
    border-radius: 4px; width: fit-content;
  }
  .coming-soon {
    background: var(--bg2); border: 1px solid var(--border);
    border-radius: 12px; padding: 60px 40px;
    text-align: center; max-width: 480px;
  }
  .cs-icon { font-size: 40px; margin-bottom: 16px; }
  .coming-soon h3 { font-size: 20px; font-weight: 600; margin-bottom: 10px; }
  .coming-soon p { font-size: 14px; color: var(--text2); }
  @media (max-width: 768px) {
    h1 { font-size: 28px; }
    .news-card { padding: 16px; }
  }
</style>