---
import Layout from '../../layouts/Layout.astro';
---
<Layout title="News">
  <section class="section">
    <div class="container">
      <span class="badge">News</span>
      <h1>GNSS Industry News</h1>
      <p class="sub">Curated news from across the GNSS industry and academic community. Updated daily.</p>
      <div class="coming-soon">
        <div class="cs-icon">📰</div>
        <h3>News feed launching soon</h3>
        <p>We are setting up our AI-assisted news curation pipeline. Check back soon.</p>
      </div>
    </div>
  </section>
</Layout>
<style>
  h1 { font-size: 36px; font-weight: 700; margin: 12px 0; }
  .sub { color: var(--text2); margin-bottom: 40px; max-width: 560px; }
  .coming-soon { background: var(--bg2); border: 1px solid var(--border); border-radius: 12px; padding: 60px 40px; text-align: center; max-width: 480px; }
  .cs-icon { font-size: 40px; margin-bottom: 16px; }
  .coming-soon h3 { font-size: 20px; font-weight: 600; margin-bottom: 10px; }
  .coming-soon p { font-size: 14px; color: var(--text2); }
</style>
