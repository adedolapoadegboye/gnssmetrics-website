---
import Layout from '../../../layouts/Layout.astro';
const articles = [
  {
    href: '/learn/timing/gnss-as-timing-source',
    title: 'GNSS as a Timing Source',
    desc: 'How satellite atomic clocks deliver nanosecond-accurate time to any receiver on Earth — the physics, the precision and why GNSS is the backbone of global time distribution.',
    time: '10 min',
  },
  {
    href: '/learn/timing/time-scales',
    title: 'Time Scales and Time Systems',
    desc: 'GPS time, GLONASS time, Galileo time, BeiDou time, UTC, TAI, UT1 and leap seconds — how they relate, how they differ and how to convert between them.',
    time: '10 min',
  },
  {
    href: '/learn/timing/timing-applications',
    title: 'Precision Timing Applications',
    desc: 'How telecommunications networks, power grids, financial systems and scientific instruments depend on GNSS timing — and what happens when it fails.',
    time: '10 min',
  },
  {
    href: '/learn/timing/clock-error',
    title: 'Clock Error and Its Effect on Positioning',
    desc: 'Receiver clock offset, satellite clock drift, the fourth unknown, relativistic corrections and how clock errors propagate into position errors.',
    time: '10 min',
  },
  {
    href: '/learn/timing/pps-output',
    title: 'PPS Output and Disciplined Oscillators',
    desc: 'The pulse-per-second signal — hardware interface, accuracy limits, holdover behaviour and GPS-disciplined oscillators (GPSDO) for critical infrastructure.',
    time: '8 min',
  },
];
---
<Layout title="GNSS Timing">
  <section class="section">
    <div class="container">

      <a href="/learn" class="back">← Learn</a>

      <div class="section-header">
        <span class="badge">Timing</span>
        <h1>GNSS Timing</h1>
        <p class="sub">
          GNSS is not just a positioning system — it is the world's most widely used
          precision timing infrastructure. Every 4G/5G base station, power grid synchronisation
          node and high-frequency trading system depends on it. This section explains
          how GNSS time works, how it is distributed, and what happens when it fails.
        </p>
        <a href="/learn/fundamentals" class="prereq">Prerequisites: GNSS Fundamentals →</a>
      </div>

      <!-- Timing dependency map -->
      <div class="dep-map">
        <div class="dep-title">Who uses GNSS timing</div>
        <div class="dep-grid">
          <div class="dep-card dep-telecom">
            <div class="dep-icon">📡</div>
            <div class="dep-name">Telecommunications</div>
            <div class="dep-detail">4G/5G base station synchronisation, frequency accuracy, handover timing</div>
          </div>
          <div class="dep-card dep-power">
            <div class="dep-icon">⚡</div>
            <div class="dep-name">Power grids</div>
            <div class="dep-detail">Synchrophasor measurement, fault location, grid synchronisation (IEEE 1588)</div>
          </div>
          <div class="dep-card dep-finance">
            <div class="dep-icon">💹</div>
            <div class="dep-name">Financial systems</div>
            <div class="dep-detail">Trade timestamping (MiFID II: 100 µs), audit trails, market synchronisation</div>
          </div>
          <div class="dep-card dep-science">
            <div class="dep-icon">🔬</div>
            <div class="dep-name">Science</div>
            <div class="dep-detail">VLBI, pulsar timing, geodesy, atmospheric research, fundamental physics</div>
          </div>
          <div class="dep-card dep-transport">
            <div class="dep-icon">🚂</div>
            <div class="dep-name">Transport</div>
            <div class="dep-detail">Rail signalling, air traffic control, maritime AIS, autonomous vehicle timing</div>
          </div>
          <div class="dep-card dep-internet">
            <div class="dep-icon">🌐</div>
            <div class="dep-name">Internet</div>
            <div class="dep-detail">NTP/PTP grandmaster clocks, DNSSEC key timing, network protocol timestamps</div>
          </div>
        </div>
      </div>

      <div class="article-list">
        {articles.map((a, i) => (
          <a href={a.href} class="article-card">
            <div class="article-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="article-body">
              <div class="article-title">{a.title}</div>
              <div class="article-desc">{a.desc}</div>
            </div>
            <div class="article-meta">
              <span class="read-time">{a.time} read</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  .back { font-size: 13px; color: var(--text2); display: inline-block; margin-bottom: 24px; transition: color 0.2s; }
  .back:hover { color: var(--accent); }
  .section-header { margin-bottom: 32px; }
  h1 { font-size: clamp(24px, 4vw, 36px); font-weight: 700; margin: 10px 0 14px; }
  .sub { color: var(--text2); max-width: 600px; font-size: 15px; line-height: 1.7; margin-bottom: 10px; }
  .prereq { font-size: 13px; color: var(--accent2); text-decoration: underline; text-underline-offset: 2px; }

  /* Dependency map */
  .dep-map { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 20px; margin-bottom: 28px; }
  .dep-title { font-size: 11px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; font-family: var(--mono); margin-bottom: 16px; }
  .dep-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
  .dep-card { background: var(--bg3); border: 1px solid var(--border); border-radius: 8px; padding: 14px; }
  .dep-telecom { border-left: 3px solid var(--accent); }
  .dep-power  { border-left: 3px solid #fbbf24; }
  .dep-finance { border-left: 3px solid #a3e635; }
  .dep-science { border-left: 3px solid var(--accent2); }
  .dep-transport { border-left: 3px solid #f97316; }
  .dep-internet { border-left: 3px solid #c084fc; }
  .dep-icon { font-size: 18px; margin-bottom: 6px; }
  .dep-name { font-size: 13px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .dep-detail { font-size: 11px; color: var(--text3); line-height: 1.5; }

  /* Article list */
  .article-list { display: flex; flex-direction: column; gap: 2px; }
  .article-card { display: grid; grid-template-columns: 48px 1fr auto; align-items: center; gap: 20px; padding: 20px 24px; background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; transition: border-color 0.2s, background 0.2s; }
  .article-card:hover { border-color: rgba(0,212,170,0.3); background: var(--bg3); }
  .article-num { font-size: 22px; font-weight: 700; font-family: var(--mono); color: var(--accent); opacity: 0.4; }
  .article-title { font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .article-desc { font-size: 13px; color: var(--text2); line-height: 1.5; }
  .article-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
  .read-time { font-size: 11px; color: var(--text3); font-family: var(--mono); white-space: nowrap; }
  .arrow { font-size: 16px; color: var(--accent); }
  @media (max-width: 768px) { .dep-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 600px) {
    .article-card { grid-template-columns: 36px 1fr; }
    .article-meta { display: none; }
    .dep-grid { grid-template-columns: 1fr; }
  }
</style>