<Layout title="PPS Output and Disciplined Oscillators">
  <section class="section">
    <div class="container learn-container">

      <nav class="breadcrumb">
        <a href="/learn">Learn</a>
        <span>›</span>
        <a href="/learn/timing">Timing</a>
        <span>›</span>
        <span>PPS Output</span>
