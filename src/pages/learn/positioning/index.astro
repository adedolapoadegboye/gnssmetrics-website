---
import Layout from '../../../layouts/Layout.astro';
const articles = [
  {
    href: '/learn/positioning/standalone-gnss',
    title: 'Standalone GNSS',
    desc: 'How a single receiver computes position from pseudoranges alone. Accuracy limits, error budget and when standalone is sufficient.',
    time: '10 min',
  },
  {
    href: '/learn/positioning/dgnss-and-sbas',
    title: 'DGNSS and SBAS',
    desc: 'Differential GNSS and satellite-based augmentation — how corrections from a reference station improve accuracy to 0.5–3 m.',
    time: '10 min',
  },
  {
    href: '/learn/positioning/rtk',
    title: 'RTK — Real-Time Kinematic',
    desc: 'Carrier phase positioning with integer ambiguity resolution. How RTK achieves centimetre accuracy and what limits it.',
    time: '14 min',
  },
  {
    href: '/learn/positioning/ppp',
    title: 'PPP — Precise Point Positioning',
    desc: 'Decimetre to centimetre accuracy without a local base station. How PPP uses precise orbit and clock products.',
    time: '12 min',
  },
  {
    href: '/learn/positioning/ppp-rtk',
    title: 'PPP-RTK',
    desc: 'The convergence of PPP and RTK — fast ambiguity resolution with global corrections. The state of the art in GNSS positioning.',
    time: '10 min',
  },
];
---
<Layout title="GNSS Positioning Methods">
  <section class="section">
    <div class="container">

      <a href="/learn" class="back">← Learn</a>

      <div class="section-header">
        <span class="badge">Positioning</span>
        <h1>Positioning Methods</h1>
        <p class="sub">
          From basic 3–5 m code positioning to centimetre-level RTK and global PPP —
          this section explains each method, when to use it and what its fundamental limits are.
          Read Fundamentals first if you haven't already.
        </p>
        <a href="/learn/fundamentals" class="prereq">
          Prerequisites: GNSS Fundamentals →
        </a>
      </div>

      <!-- Accuracy spectrum -->
      <div class="accuracy-spectrum">
        <div class="spectrum-title">Positioning accuracy by method</div>
        <div class="spectrum-bar">
          <div class="spectrum-item" style="left:0%; width:30%; background:rgba(255,71,87,0.15); border-color:rgba(255,71,87,0.3);">
            <div class="spec-label">Standalone</div>
            <div class="spec-range">2 – 10 m</div>
          </div>
          <div class="spectrum-item" style="left:28%; width:22%; background:rgba(240,165,0,0.15); border-color:rgba(240,165,0,0.3);">
            <div class="spec-label">DGNSS/SBAS</div>
            <div class="spec-range">0.5 – 3 m</div>
          </div>
          <div class="spectrum-item" style="left:48%; width:20%; background:rgba(251,191,36,0.15); border-color:rgba(251,191,36,0.3);">
            <div class="spec-label">PPP</div>
            <div class="spec-range">5 – 30 cm</div>
          </div>
          <div class="spectrum-item" style="left:66%; width:18%; background:rgba(0,212,170,0.12); border-color:rgba(0,212,170,0.3);">
            <div class="spec-label">PPP-RTK</div>
            <div class="spec-range">2 – 10 cm</div>
          </div>
          <div class="spectrum-item" style="left:82%; width:18%; background:rgba(0,212,170,0.2); border-color:rgba(0,212,170,0.5);">
            <div class="spec-label">RTK</div>
            <div class="spec-range">1 – 3 cm</div>
          </div>
        </div>
        <div class="spectrum-axis">
          <span>10 m</span>
          <span>1 m</span>
          <span>10 cm</span>
          <span>1 cm</span>
        </div>
      </div>

      <div class="article-list">
        {articles.map((a, i) => (
          <a href={a.href} class="article-card">
            <div class="article-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="article-body">
              <div class="article-title">{a.title}</div>
              <div class="article-desc">{a.desc}</div>
            </div>
            <div class="article-meta">
              <span class="read-time">{a.time} read</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  .back { font-size: 13px; color: var(--text2); display: inline-block; margin-bottom: 24px; transition: color 0.2s; }
  .back:hover { color: var(--accent); }
  .section-header { margin-bottom: 32px; }
  h1 { font-size: clamp(24px, 4vw, 36px); font-weight: 700; margin: 10px 0 14px; }
  .sub { color: var(--text2); max-width: 600px; font-size: 15px; line-height: 1.7; margin-bottom: 10px; }
  .prereq { font-size: 13px; color: var(--accent2); text-decoration: underline; text-underline-offset: 2px; }

  /* Accuracy spectrum */
  .accuracy-spectrum { background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; padding: 20px; margin-bottom: 28px; }
  .spectrum-title { font-size: 12px; font-weight: 600; color: var(--text3); text-transform: uppercase; letter-spacing: 0.08em; font-family: var(--mono); margin-bottom: 16px; }
  .spectrum-bar { position: relative; height: 64px; margin-bottom: 8px; }
  .spectrum-item { position: absolute; height: 56px; border: 1px solid; border-radius: 6px; display: flex; flex-direction: column; justify-content: center; align-items: center; }
  .spec-label { font-size: 11px; font-weight: 600; color: var(--text); }
  .spec-range { font-size: 10px; color: var(--text3); font-family: var(--mono); }
  .spectrum-axis { display: flex; justify-content: space-between; font-size: 10px; color: var(--text3); font-family: var(--mono); padding: 0 2px; }

  /* Article list */
  .article-list { display: flex; flex-direction: column; gap: 2px; }
  .article-card { display: grid; grid-template-columns: 48px 1fr auto; align-items: center; gap: 20px; padding: 20px 24px; background: var(--bg2); border: 1px solid var(--border); border-radius: 10px; transition: border-color 0.2s, background 0.2s; }
  .article-card:hover { border-color: rgba(0,212,170,0.3); background: var(--bg3); }
  .article-num { font-size: 22px; font-weight: 700; font-family: var(--mono); color: var(--accent); opacity: 0.4; }
  .article-title { font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .article-desc { font-size: 13px; color: var(--text2); line-height: 1.5; }
  .article-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
  .read-time { font-size: 11px; color: var(--text3); font-family: var(--mono); white-space: nowrap; }
  .arrow { font-size: 16px; color: var(--accent); }
  @media (max-width: 600px) {
    .article-card { grid-template-columns: 36px 1fr; }
    .article-meta { display: none; }
    .spectrum-bar { height: 100px; }
    .spectrum-item { height: auto; padding: 6px 4px; }
  }
</style>