---
import Layout from '../../../layouts/Layout.astro';
const articles = [
  {
    href: '/learn/fundamentals/how-gnss-works',
    title: 'How GNSS Works',
    desc: 'Trilateration, pseudoranges, signal travel time and why you need four satellites minimum.',
    time: '12 min',
  },
  {
    href: '/learn/fundamentals/signals-and-frequencies',
    title: 'GNSS Signals and Frequencies',
    desc: 'L-band frequencies, signal structure, CDMA vs FDMA, spreading codes and carrier phase.',
    time: '10 min',
  },
  {
    href: '/learn/fundamentals/error-sources',
    title: 'Error Sources',
    desc: 'Ionospheric delay, tropospheric delay, multipath, clock errors and ephemeris errors — causes, magnitudes and mitigations.',
    time: '14 min',
  },
  {
    href: '/learn/fundamentals/coordinate-systems',
    title: 'Coordinate Systems',
    desc: 'WGS84, ECEF, ENU, geodetic and Cartesian coordinates — how they relate and when to use each.',
    time: '10 min',
  },
  {
    href: '/learn/fundamentals/dilution-of-precision',
    title: 'Dilution of Precision (DOP)',
    desc: 'PDOP, HDOP, VDOP, GDOP — what they measure, how satellite geometry affects accuracy, and what values matter.',
    time: '8 min',
  },
];
---
<Layout title="GNSS Fundamentals">
  <section class="section">
    <div class="container">

      <a href="/learn" class="back">← Learn</a>

      <div class="section-header">
        <span class="badge">Fundamentals</span>
        <h1>GNSS Fundamentals</h1>
        <p class="sub">
          Everything starts here. These articles build the mental model you need before tackling
          positioning methods, protocols or mathematics. Start with How GNSS Works and read in order.
        </p>
      </div>

      <div class="article-list">
        {articles.map((a, i) => (
          <a href={a.href} class="article-card">
            <div class="article-num">{String(i + 1).padStart(2, '0')}</div>
            <div class="article-body">
              <div class="article-title">{a.title}</div>
              <div class="article-desc">{a.desc}</div>
            </div>
            <div class="article-meta">
              <span class="read-time">{a.time} read</span>
              <span class="arrow">→</span>
            </div>
          </a>
        ))}
      </div>

    </div>
  </section>
</Layout>

<style>
  .back { font-size: 13px; color: var(--text2); display: inline-block; margin-bottom: 24px; transition: color 0.2s; }
  .back:hover { color: var(--accent); }
  .section-header { margin-bottom: 40px; }
  h1 { font-size: clamp(24px, 4vw, 36px); font-weight: 700; margin: 10px 0 14px; }
  .sub { color: var(--text2); max-width: 600px; font-size: 15px; line-height: 1.7; }
  .article-list { display: flex; flex-direction: column; gap: 2px; }
  .article-card {
    display: grid; grid-template-columns: 48px 1fr auto;
    align-items: center; gap: 20px;
    padding: 20px 24px; background: var(--bg2);
    border: 1px solid var(--border); border-radius: 10px;
    transition: border-color 0.2s, background 0.2s;
  }
  .article-card:hover { border-color: rgba(0,212,170,0.3); background: var(--bg3); }
  .article-num {
    font-size: 22px; font-weight: 700; font-family: var(--mono);
    color: var(--accent); opacity: 0.4; line-height: 1;
  }
  .article-title { font-size: 16px; font-weight: 600; color: var(--text); margin-bottom: 4px; }
  .article-desc { font-size: 13px; color: var(--text2); line-height: 1.5; }
  .article-meta { display: flex; flex-direction: column; align-items: flex-end; gap: 6px; }
  .read-time { font-size: 11px; color: var(--text3); font-family: var(--mono); white-space: nowrap; }
  .arrow { font-size: 16px; color: var(--accent); }
  @media (max-width: 600px) {
    .article-card { grid-template-columns: 36px 1fr; }
    .article-meta { display: none; }
  }
</style>